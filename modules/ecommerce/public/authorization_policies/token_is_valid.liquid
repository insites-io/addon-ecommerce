---
name: token_is_valid
redirect_to: 403
---
{%- graphql data =  'modules/ecommerce/account/get_user_with_password_token', id: context.params.id | dig: 'users' | dig: 'results' | first -%}
{%- assign token_valid = context.params.token | is_token_valid: data.id -%}
{% if data.id != blank and token_valid == true and data.default[0].password_token == context.params.token %}true{% endif %}