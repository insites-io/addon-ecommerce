---
name: order_created_date_valid
redirect_to: sign-in
flash_alert: Order confirmation page has expired. Please login to view order details.
---
{%- comment -%}
  This policy ONLY denies a valid-but-expired order (>10 min old), so the
  "expired" flash + sign-in redirect apply to it. Invalid / forged / blank ids
  are intentionally allowed through here and handled by the page
  (confirmation.liquid redirects them to /404). A policy can only redirect to a
  single destination, so the page does the branching: invalid -> /404,
  expired -> sign-in.
{%- endcomment -%}
{%- if context.params.id == blank -%}
    true
{%- else -%}
    {% graphql order_details = "modules/ecommerce/orders/get_order_details",
        uuid: context.params.id | dig: 'items' | dig: 'results' | first %}

    {%- comment -%} No matching order (bad/forged id) — allow through; the page redirects it to /404. {%- endcomment -%}
    {%- if order_details == blank or order_details.created_at == blank -%}
        true
    {%- else -%}
        {% assign now = 'now' | to_time %}
        {% comment %} Using plus filter will convert string into int {% endcomment %}
        {% assign diff = order_details.created_at | time_diff: now, 'minutes' | plus: 0 %}
        {% comment %} Allow user to see confirmation page for 10 minutes {% endcomment %}
        {%- if diff < 10 -%}
            true
        {%- else -%}
            false
        {%- endif -%}
    {%- endif -%}
{%- endif -%}