---
metadata: {
    partial_name: 'Ecommerce | Order Items | Create Order Items'
}
---

{% function user_cart_uuid = 'modules/ecommerce/user/get_user_uuid' %}

{%  liquid    
    ## Get cart
    if user_cart_uuid and user_cart_uuid != ''
        assign cart_items = '' | split: ','     
        ## Discount details will be used in the export to create an Order Discounts item.
        graphql cart = 'modules/ecommerce/carts/get_cart', contact_uuid: user_cart_uuid, show_discount_details: true | dig: 'items','results' | first 
        assign cart_items = cart.cart_items
    endif

    ## Get product info
    assign product_uuids = cart_items | array_map: 'product_uuid' | array_flatten
    graphql products = 'modules/ecommerce/products/get_cart_products', uuid: product_uuids, size: cart_items.size | dig: 'items','results'
%}    

{% comment %} Create data for order_items  {% endcomment %}
{%  liquid   

    assign order_items = '[]' | parse_json

    ## This variable is use in creating preorder events and preorder email notification
    assign total_preorder_items = 0

    for cart_item in cart_items

        assign product = products | array_detect: uuid: cart_item.product_uuid
        assign product_name = product.product_name                

        ## Check if the cart_item is a product or a variant of the product
        if cart_item.product_variant_uuid == '' or cart_item.product_variant_uuid == null
            ## item is NOT a variant
            assign selected_prop = product
        else 
            ## cart_item is a variant                
            for variant in product.variants
                if cart_item.product_variant_uuid == variant.uuid
                    assign selected_prop = variant
                endif
            endfor
        endif            

        ## Stock level / Pre-order items
        if selected_prop.stock_level < 1
            assign total_preorder_items = total_preorder_items | plus: 1
        endif

        ## Price
        if selected_prop.is_on_sale == true 
            assign price = selected_prop.sale_price
        else 
            assign price = selected_prop.regular_price
        endif 

        assign order_item_image = selected_prop.product_image.url | replace: ' ', '%20' | escape | default: ''

        assign properties = '' | parse_json
        assign properties = properties | add_hash_key: 'order.uuid', order_uuid
        assign properties = properties | add_hash_key: 'product.uuid', cart_item.product_uuid
        assign properties = properties | add_hash_key: 'product_variant.uuid', cart_item.product_variant_uuid
        if order_item_image
            assign properties = properties | add_hash_key: 'order_item_image', order_item_image
        endif
        assign properties = properties | add_hash_key: 'order_item_name', product_name
        assign properties = properties | add_hash_key: 'sku', selected_prop.product_sku
        assign temp_cart_item_quantity = cart_item.quantity | plus: 0
        assign properties = properties | add_hash_key: 'quantity', temp_cart_item_quantity
        assign properties = properties | add_hash_key: 'is_fixed_tax_amount', selected_prop.is_fixed_tax_amount
        if selected_prop.is_on_sale == true
            assign unit_price_includes_tax = selected_prop.is_sale_price_tax_included
        else
            assign unit_price_includes_tax = selected_prop.is_tax_included
        endif
        assign properties = properties | add_hash_key: 'unit_price_includes_tax', unit_price_includes_tax
        assign properties = properties | add_hash_key: 'unit_price', price
        assign temp_tax_amount = selected_prop.tax_amount | default: 0.0
        assign properties = properties | add_hash_key: 'tax_amount', temp_tax_amount

        ## Calculate item_price (per-unit price excluding tax) and item_tax (per-unit tax amount)
        if unit_price_includes_tax == true
            if selected_prop.is_fixed_tax_amount == true
                assign item_price = price | minus: temp_tax_amount
                assign item_tax = temp_tax_amount
            else
                assign temp_tax_rate = temp_tax_amount | divided_by: 100.0
                assign temp_tax_divisor = temp_tax_rate | plus: 1
                assign item_price = price | divided_by: temp_tax_divisor
                assign item_tax = price | minus: item_price
            endif
        else
            assign item_price = price
            if selected_prop.is_fixed_tax_amount == true
                assign item_tax = temp_tax_amount
            else
                assign item_tax = price | times: temp_tax_amount | divided_by: 100.0
            endif
        endif

        assign item_price = item_price | round: 4
        assign item_tax = item_tax | round: 4
        assign properties = properties | add_hash_key: 'item_price', item_price
        assign properties = properties | add_hash_key: 'item_tax', item_tax
        assign temp_line_item_tax = item_tax | times: temp_cart_item_quantity | round: 4
        assign properties = properties | add_hash_key: 'line_item_tax', temp_line_item_tax
        comment
            These items are to be readded when needed, consult Insites for changes in fields
            assign temp_line_item_price = price | times: temp_cart_item_quantity
            assign properties = properties | add_hash_key: 'line_item_price', temp_line_item_price
        endcomment
        assign temp_item_subtotal = item_price | times: temp_cart_item_quantity
        assign line_item_total = temp_item_subtotal | plus: temp_line_item_tax | round: 4
        assign properties = properties | add_hash_key: 'line_item_total', line_item_total

        assign order_items = order_items | array_add: properties
    endfor
    
    function create_order_item = "ecommerce/controller/order_items/add_bulk", params: order_items

%}


{% export cart, total_preorder_items %}