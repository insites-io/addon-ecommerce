---
metadata: {
    partial_name: 'Ecommerce | Layout | Pagination'
}
---

<ins-table no-wrap
    static-table
    class="for-pagination-only"
    id="insBaseTable"
    without-search>    
</ins-table>

<script>
    var insBaseTable = document.getElementById('insBaseTable');

    insBaseTable.pageSizeOptions = [9,15,30];
    insBaseTable.totalCount = {{ data.total_entries }};
    insBaseTable.pageNumber = {{ data.current_page }};
    insBaseTable.pageSize = {{ data.per_page |  default: 10}};
    insBaseTable.paginationText = "{{ label }}";    
    
    insBaseTable.addEventListener('insPaginationChange', tablePaginationHandler);

    function tablePaginationHandler(event) {
        const pageSize = event.detail.pageSize;
        const pageNumber = event.detail.pageNumber;

        // Use URL object for robust parsing
        const url = new URL(window.location.href);

        // Get current query parameters
        const params = url.searchParams;

        // Remove existing page and per_page params
        params.delete('page');
        params.delete('per_page');

        // Set new pagination params
        params.set('page', pageNumber);
        params.set('per_page', pageSize);

        // Set the updated search params back to the URL object
        url.search = params.toString();

        // Redirect to the new URL
        window.location.href = url.toString();
    }
</script>