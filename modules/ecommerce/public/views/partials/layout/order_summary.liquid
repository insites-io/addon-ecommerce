---
metadata: {
    partial_name: 'Ecommerce | Layout | Order Summary'
}
---

{%- 
    liquid

    assign params = context.params
    function user_uuid = 'modules/ecommerce/user/get_user_uuid'

    if is_ordered_items == true and order_uuid != ''
        ## Get Order Summary for already purchased item(s) 
        graphql carts = 'modules/ecommerce/order_items/get_order_items', order_uuid: order_uuid  | dig: 'items','results'
    else
        ## Get Cart Items
        include 'modules/ecommerce/carts/cart_items'
        assign cart_items = context.exports.cart_items
        assign user_cart = cart_items.user_cart
        assign carts = cart_items.carts
        assign products = cart_items.products
        assign discounts = user_cart.discounts
    endif

    comment
        No items in the Cart: Do not allow user to enter checkout pages 
    endcomment
    if carts == null or carts.size <= 0
        if context.params.slug == 'checkout'
            redirect_to '/products'
        endif
    endif

-%}


<div id="order-summary-main-wrap" class="show-for-medium {% if context.params.slug == 'confirmation' %}force-show{% endif %}">    
    {% unless no_heading %}
        <div class="spacer x-large show-for-small-only"></div>
        <h4>Order summary</h4>
        <div class="spacer x-large hide-for-small-only"></div>
        <div class="spacer show-for-small-only"></div>
    {% endunless %}
    <div id="order-summary-cart-wrap" class="order-summary">  
        {%- if show_product -%}   
            {%- for item in carts -%}
                {% comment %} ? TAX LABEL {% endcomment %}
                {%- if item.is_fixed_tax_amount -%}
                    {%- assign tax_label = "Includes Tax" -%}
                {%- else -%}
                    {%- assign tax_label = "Tax" -%}
                {%- endif -%}

                {%- if params.slug == 'confirmation' and params.id != '' -%}
                    {%-  
                        liquid 
                        assign cart = '' | parse_json
                        assign cart = cart | add_hash_key: 'product_name', item.order_item_name
                        assign cart = cart | add_hash_key: 'price', item.unit_price
                    -%}
                {%- else -%}
                    {%- include 'modules/ecommerce/carts/cart_details', products, item -%}
                    {%- assign cart = context.exports.cart -%}
                {%- endif -%}

                <div class="grid-x grid-padding-x body-large">
                    <div class="product-name large-6 medium-8 small-6 cell">
                        <p class="font-color-sub">{{ cart.product_name }}</p>
                    </div>
                    <div class="text-right large-3 medium-4 small-2 cell">                        
                        <p>{{ item.quantity }}x</p>
                    </div>
                    <div class="text-right large-3 medium-12 small-4 cell">
                        {%- assign item_amount = cart.price | advanced_format: '%.2f' | default: "0.00" -%}
                        {%- assign item_amount = item_amount | pricify -%}
                        {%- unless item_amount contains '.' -%}
                            {%- assign item_amount = item_amount | append: '.00' -%}
                        {%- endunless -%}
                        <p class="font-color-sub">{{ item_amount }}</p>
                    </div>
                </div>
                {%- unless forloop.last -%}
                    <div class="spacer small"></div>
                {%- endunless -%}
            
            {%- endfor -%}
        {%- endif -%}
    </div>

    {%- if show_product and carts.size > 0 -%}
        <div class="spacer"></div>
        <hr>
        <div class="spacer"></div>
    {%- endif -%}


    {% comment %}--- VALIDATE DISCOUNT CODES ---{% endcomment %}
    {% assign total_discount_item_deleted = 0 %}
    {%- for item in discounts -%}
        {%- if is_ordered_items != true -%}
             {% comment %} Run function to re-validate & auto delete invalid discount codes {% endcomment %}
             {%- if context.params.slug2 == 'payment' or context.params.slug == 'checkout' -%}
                {%- parse_json payload -%}
                {
                    "check_duplicates": false,
                    "delete_invalid": true,
                    "contact_uuid": "{{ user_uuid }}",
                    "discount_code": "{{ item.discount_code }}",
                    "total_cart_value": {{ total_cart_value | default: 0 }}
                }
                {%- endparse_json -%}
                {%- function validate_code = "modules/ecommerce/checkout/validate_discount_code", payload: payload -%}
                {% assign total_discount_item_deleted = total_discount_item_deleted | plus: validate_code.deleted_item %}
            {%- endif -%}
        {%- endif -%}
    {%- endfor -%}
    {% if total_discount_item_deleted > 0 %}
        {% comment %} Get the updated discounts {% endcomment %}
        {% graphql discounts = 'modules/ecommerce/carts/get_cart_discounts' | dig: 'items','results' %}
    {% endif %} 

    
    {% comment %}--- GET ORDER COMPUTATION SUMMARY ---{% endcomment %}
    {%- if is_ordered_items == true and order_uuid != '' -%}
        {% include 'modules/ecommerce/checkout/compute_completed_order_amounts', uuid: order_uuid %}
    {%- else -%}
        {%- include 'modules/ecommerce/checkout/compute_order_summary', user_cart, carts, products, discounts -%}
    {%- endif -%}
    {%- assign computed = context.exports.computed -%}

   {% comment %} Subtotal {% endcomment %}
    <div class="grid-x grid-padding-x">
        <div class="large-6 medium-6 small-6 cell">
            <p class="font-color-sub bold">Subtotal</p>
        </div>
        <div class="large-6 medium-6 small-6 cell text-right">
            {%- assign sub_total = computed.sub_total_amount | advanced_format: '%.2f' | default: "0.00" -%}
            {%- assign sub_total = sub_total | pricify -%}
            {%- unless sub_total contains '.' -%}
                {%- assign sub_total = sub_total | append: '.00' -%}
            {%- endunless -%}
            <p id="summary_subtotal">{{ sub_total }}</p>
        </div>
    </div>
    <div class="spacer x-small"></div>

    {% comment %} Delivery & handling {% endcomment %}
    <div class="grid-x grid-padding-x">
        <div class="large-6 medium-6 small-6 cell">
            <p class="font-color-sub bold">Delivery & handling</p>
        </div>
        <div class="large-6 medium-6 small-6 cell text-right">
            {%- assign shipping_cost = computed.shipping_amount | advanced_format: '%.2f' | default: "0.00" -%}
            {%- assign shipping_cost = shipping_cost | pricify -%}
            {%- unless shipping_cost contains '.' -%}
                {%- assign shipping_cost = shipping_cost | append: '.00' -%}
            {%- endunless -%}
            <p id="summary_delivery">{{ shipping_cost }}</p>
        </div>
    </div>     
    <div class="spacer x-small"></div>           
    
    {% comment %} Discounts {% endcomment %}
    {%- if discounts.size > 0 or computed.total_discount_amount > 0 -%}
        
        <div class="list-discount-codes">
            <div class="grid-x">
                <div class="small-6 medium-6 large-8 cell">
                    <p class="font-color-sub bold">Discounts</p>
                </div>
                <div class="small-6 medium-6 large-4 cell text-right">
                    {%- if computed.total_discount_amount > 0 -%}
                        {%- assign total_discount_amount = computed.total_discount_amount | advanced_format: '%.2f' | default: 0 -%}
                        {%- assign total_discount_amount = total_discount_amount | pricify -%}
                        {%- unless total_discount_amount contains '.' -%}
                            {%- assign total_discount_amount = total_discount_amount | append: '.00' -%}
                        {%- endunless -%}
                        <p>{{ total_discount_amount | prepend: '- '}}</p>
                    {%- endif -%}
                </div>
            </div>
            <div class="spacer x-small"></div>

            {%- for item in discounts -%}
                {%- assign type = item.discount_type | downcase -%}
                {%- if type contains "fix" -%}
                    {%- assign value = item.discount_value | advanced_format: "%.2f" -%}
                    {%- assign value = value | pricify -%}
                    {%- unless value contains '.' -%}
                        {%- assign value = value | append: '.00' -%}
                    {%- endunless -%}
                    {%- assign value = value | append: " Off" -%}
                {%- elsif type contains "percent" -%}
                    {%- assign value = item.discount_value | replace: '.00', '.0' -%}
                    {%- assign value = value | replace: '.0', '' -%}
                    {%- assign value = value | append: "% Off" -%}
                {%- else -%}
                    {%- assign value = item.discount_type -%}
                {%- endif -%}
                {%- unless value contains "hipping" -%}{% comment %} <-- not a typo {% endcomment %}
                    {%- 
                        liquid 
                        if type contains "shipping"
                            assign value = value | append: " Shipping"
                        endif
                    -%}
                {%- endunless -%}
                
                <div class="list-discount-codes--item" data-id="{{ item.id }}" data-uuid="{{ item.uuid }}" data-contact-uuid="{{ user_uuid }}">
                    <div class="body-medium">
                        <p class="font-color-head bold">{{ value }}</p>
                        <p>{{ item.discount_name }}</p>
                        {%- if item.minimum_cart_value > 0 -%}
                            <div class="spacer xx-small"></div>
                            <p>Minimum ${{ item.minimum_cart_value | advanced_format: "%.2f" }} Purchase</p>
                        {%- endif -%}
                    </div>
                    <div class="icon-close"></div>
                </div>
            {%- endfor -%}
        </div>
        <div class="spacer x-small"></div>                
    {%- endif -%}
    {% comment %} END Discount Codes {% endcomment %}

    {% comment %} Tax {% endcomment %}
    <div class="grid-x grid-padding-x">
        {% comment %} ? Confirmation {% endcomment %}
        {%- if context.params.slug == 'confirmation' -%}
            {% comment %} ? Tax Applied = Both or Single {% endcomment %}
            {%- if context.session.tax_applied == "both" -%}
                {% comment %} ? IF BOTH INCLUDES AND NOT INCLUDES TAX IS ON CART {% endcomment %}
                <div class="large-6 medium-6 small-6 cell pb-8">
                    <p class="font-color-sub bold" id="summary_tax_label">Includes Tax</p>
                </div>
                <div class="large-6 medium-6 small-6 cell text-right">
                    {%- assign sub_total_tax_included = context.session.sub_total_tax_included | advanced_format: '%.2f' | default: "0.00" -%}
                    {%- assign sub_total_tax_included = sub_total_tax_included | pricify -%}
                    {%- unless sub_total_tax_included contains '.' -%}
                        {%- assign sub_total_tax_included = sub_total_tax_included | append: '.00' -%}
                    {%- endunless -%}
                    <p id="summary_tax">({{ sub_total_tax_included }})</p>
                </div>

                <div class="large-6 medium-6 small-6 cell">
                    <p class="font-color-sub bold" id="summary_tax_label">Tax</p>
                </div>
                <div class="large-6 medium-6 small-6 cell text-right">
                    {%- assign sub_total_tax_not_included = context.session.sub_total_tax_not_included | advanced_format: '%.2f' | default: "0.00" -%}
                    {%- assign sub_total_tax_not_included = sub_total_tax_not_included | pricify -%}
                    {%- unless sub_total_tax_not_included contains '.' -%}
                        {%- assign sub_total_tax_not_included = sub_total_tax_not_included | append: '.00' -%}
                    {%- endunless -%}
                    <p id="summary_tax">{{ sub_total_tax_not_included }}</p>
                </div>
            {%- else -%}
                <div class="large-6 medium-6 small-6 cell">
                    <p class="font-color-sub bold" id="summary_tax_label">{{ computed.tax_label | default: 'Tax' }}</p>
                </div>
                <div class="large-6 medium-6 small-6 cell text-right">
                    {%- assign tax_amount = computed.tax_amount | advanced_format: '%.2f' | default: "0.00" -%}
                    {%- assign tax_amount = tax_amount | pricify -%}
                    {%- unless tax_amount contains '.' -%}
                        {%- assign tax_amount = tax_amount | append: '.00' -%}
                    {%- endunless -%}
                    {%- if context.session.sub_total_tax_included != 0 -%}
                        <p id="summary_tax">{{ tax_amount }}</p>
                    {%- else -%}
                        <p id="summary_tax">{{ tax_amount }}</p>
                    {%- endif -%}
                </div>
            {%- endif -%}
        {%- else -%}
            {%- if computed.tax_applied == "both" -%}
                {% comment %} ? IF BOTH INCLUDES AND NOT INCLUDES TAX IS ON CART {% endcomment %}
                <div class="large-6 medium-6 small-6 cell pb-8">
                    <p class="font-color-sub bold" id="summary_tax_label">Includes Tax </p>
                </div>
                <div class="large-6 medium-6 small-6 cell text-right">
                    {%- assign sub_total_tax_included = computed.sub_total_tax_included | advanced_format: '%.2f' | default: "0.00" -%}
                    {%- assign sub_total_tax_included = sub_total_tax_included | pricify -%}
                    {%- unless sub_total_tax_included contains '.' -%}
                        {%- assign sub_total_tax_included = sub_total_tax_included | append: '.00' -%}
                    {%- endunless -%}
                    <p id="summary_tax">({{ sub_total_tax_included }})</p>
                </div>

                <div class="large-6 medium-6 small-6 cell">
                    <p class="font-color-sub bold" id="summary_tax_label">Tax </p>
                </div>
                <div class="large-6 medium-6 small-6 cell text-right">
                    {%- assign sub_total_tax_not_included = computed.sub_total_tax_not_included | advanced_format: '%.2f' | default: "0.00" -%}
                    {%- assign sub_total_tax_not_included = sub_total_tax_not_included | pricify -%}
                    {%- unless sub_total_tax_not_included contains '.' -%}
                        {%- assign sub_total_tax_not_included = sub_total_tax_not_included | append: '.00' -%}
                    {%- endunless -%}
                    <p id="summary_tax">{{ sub_total_tax_not_included }}</p>
                </div>
            {%- else -%}
                {% comment %} ? IF SINGLE TAX IS ON CARD {% endcomment %}
                <div class="large-6 medium-6 small-6 cell">
                    <p class="font-color-sub bold" id="summary_tax_label">{{ computed.tax_label | default: 'Tax' }}</p>
                </div>
                <div class="large-6 medium-6 small-6 cell text-right">
                    {%- assign tax_amount = computed.tax_amount | advanced_format: '%.2f' | default: "0.00" -%}
                    {%- assign tax_amount = tax_amount | pricify -%}
                    {%- unless tax_amount contains '.' -%}
                        {%- assign tax_amount = tax_amount | append: '.00' -%}
                    {%- endunless -%}
                    {%- if computed.sub_total_tax_included != 0 -%}
                        <p id="summary_tax">{{ tax_amount }}</p>
                    {%- else -%}
                        <p id="summary_tax">{{ tax_amount }}</p>
                    {%- endif -%}
                </div>
            {%- endif -%}
        {%- endif -%}
    </div>
    <div class="spacer x-small"></div> 


       {% comment %} Processing Fee {% endcomment %}
       <div class="grid-x grid-padding-x">
        <div class="large-6 medium-6 small-6 cell">
            <p class="font-color-sub bold">Processing fee (1.7%)</p>
        </div>
        <div class="large-6 medium-6 small-6 cell text-right">
            {%- assign processing_fee = computed.processing_fee | advanced_format: '%.2f' | default: "0.00" -%}
            {%- assign processing_fee = processing_fee | pricify -%}
            {%- unless processing_fee contains '.' -%}
                {%- assign processing_fee = processing_fee | append: '.00' -%}
            {%- endunless -%}
            <p id="summary_processing_fee">{{ processing_fee }}</p>
        </div>
    </div>
    <div class="spacer medium"></div>    
    <hr>
    <div class="spacer medium"></div>

    <div class="grid-x grid-padding-x font-color-head">
        <div class="large-6 medium-6 small-6 cell">
            <p class="order-total">Total</p>
        </div>
        <div class="large-6 medium-6 small-6 cell text-right">
            {%- assign total_amount = computed.total_amount | advanced_format: '%.2f' | default: "0.00" -%}
            {%- assign total_amount = total_amount | pricify -%}
            {%- unless total_amount contains '.' -%}
                {%- assign total_amount = total_amount | append: '.00' -%}
            {%- endunless -%}            
            <p id="summary_total" class="order-total">{{ total_amount }}</p>
        </div>
    </div>

    {%- if context.params.slug == 'shopping-cart' -%}
        <div class="spacer x-large"></div>
        <div class="notes-wrap">
            <p class="body-small bold">Notes</p>
            <ul class="body-x-small">
                <li>Shipping costs will be calculated during checkout.</li>
                <li>Tax and processing fees may be adjusted based on the shipping cost.</li>
            </ul>
        </div>
    {%- endif -%}    

</div>

{%- unless context.params.slug == 'confirmation' -%}
<div id="mobile-order-summary" class="show-for-small-only">
    <div class="total">
        <p class="color-ui-05 body-x-small">Total</p>
        <p class="order-total">{{ total_amount }}</p>
    </div>
    <ins-button type="button" id="view-order-summary-btn" label="View order summary"></ins-button>
</div>
{%- endunless -%}

<ins-drawer 
  custom-width="430px" 
  position="right" 
  bordered=false
  id="order-summary-drawer"
  class="mobile-order-summary inline">
    <div id="order-summary-drawer-content">       

    </div>
    <div class="spacer x-large"></div>
    <div class="show-for-small-only">
        {%- liquid
            include 'modules/ecommerce/discounts/add_discount_code_form_mobile', total_cart_value: total_cart_value
        -%}
    </div>
    {%- if context.params.slug != 'checkout' -%}
        <div class="spacer x-large"></div>
        <ins-button label="Proceed to checkout" solid color="blue" class="checkoutBtn proceed-to-checkout-btn full" onclick="document.location.href = '/checkout';"></ins-button>
    {%- endif -%}
</ins-drawer>

<script>
    let orderSummaryMainWrap = document.getElementById('order-summary-main-wrap');
    let viewOrderSummaryBtn = document.getElementById('view-order-summary-btn');
    let orderSummaryDrawer = document.getElementById('order-summary-drawer');
    let orderSummaryDrawerContent = document.getElementById('order-summary-drawer-content');
    var total_discount_item_deleted = {{ total_discount_item_deleted | default: 0 }};

    viewOrderSummaryBtn.addEventListener('insClick', async event => {
        let orderSummaryHtmlContent = orderSummaryMainWrap.innerHTML;
        // Replace 'id' with 'data'
        let modifiedHTML = orderSummaryHtmlContent.replace(/\bid="([^"]+)"/g, 'data="$1"');

        orderSummaryDrawer.setDrawerState(true); 
        orderSummaryDrawerContent.innerHTML = modifiedHTML;
    });    
</script>