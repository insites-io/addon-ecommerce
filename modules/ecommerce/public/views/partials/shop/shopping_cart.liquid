---
metadata: {
    partial_name: 'Ecommerce | Shop | Shopping Cart'
}
---
{%- if cart_items.size > 0 -%}
    <h2 class="heading-4">Cart items</h2>
    <div class="spacer x-large"></div>    
    <div id="shopping-cart-list">
        <div class="wrap shopping-cart grid-y">

        {%- for item in cart_items -%}          

            {% include 'modules/ecommerce/carts/cart_item_details', products, item %}
            {% assign cart = context.exports.cart %}
            
                                                
            <div id="shop-cart-item-{{cart.selected_prop.id}}" class="cart-item-wrap cell">
                {% if forloop.first == false %}
                    <hr>
                    <div class="spacer x-large"></div>
                {% endif %}
                <div class="grid-x" >
                    <div class="img-wrap">
                        {% if cart.imgsrc != '' and cart.imgsrc != blank %}
                            <img  src="{{ cart.imgsrc | replace: ' ', '%20' | escape }}" width="88" height="88" alt="{{ cart.product_name }}" >
                        {% else %}
                            {% include 'modules/website/layout/placeholder_image', size: 'medium' %}
                        {% endif %}
                    </div>
                    <div class="text-wrap">
                        <a href="/products/{{ cart.slug }}">
                            <h3 class="heading-6">
                                {{ cart.product_name }} 

                                {% comment %} Pre-order Tag {% endcomment %}                                
                                {% if cart.selected_prop.stock_level < item.quantity %}
                                    <ins-tag label="Pre-order" class='preorder-tag body-x-small' ></ins-tag>
                                {% endif %}
                            </h3> 
                        </a>
                        <p class="body-small font-color-body">SKU: {{ cart.product_sku }}</p>                        
                        <div class="spacer small"></div>

                        {% comment %} Print variant info {% endcomment %}
                        {% include 'modules/ecommerce/variants/variants', item: item, selected_prop: cart.selected_prop %}
                        
                        <p>
                            <span class="body-x-small-bold">Price:</span>
                            <span class="body-x-small item-price">{{ cart.price | pricify }}</span>
                            {% if cart.selected_prop.is_on_sale == true %}
                            <span class="body-x-small strikethrough">{{ cart.price_strikethrough | pricify }}</span>
                            {% endif %}
                        </p>
                    </div>
                    <div class="btn-wrap grid-y">
                        <p class="cart-price compute-price">{{ cart.item_total_price | pricify: 'USD', no_cents_if_whole: false }}</p>
                        <div class="spacer small"></div>
                        <ins-input-stepper
                            class="cart-stepper" 
                            data-id="{{ item.id }}"
                            data-product_uuid="{{ item.product_uuid }}"
                            data-product_sku="{{ item.product_sku }}"
                            data-variant_uuid="{{ item.product_variant_uuid }}"
                            data-product_name="{{ item.product_name }}"
                            data-stock_level="{{ selected_prop.stock_level | default: 0 }}"
                            value="{{ item.quantity }}" 
                            step="1" min="1"                             
                            small>
                        </ins-input-stepper>
                        <div class="spacer small"></div>
                        <div class="text-right" >
                            {% comment %} Use these IDs to validate item deletion, as the API does not implement an authentication policy. {% endcomment %}
                            {% parse_json remove_item %}
                            {
                                "id": "{{ item.id }}",
                                "uuid": "{{ item.uuid }}",
                                "cart_uuid": "{{ item.cart_uuid }}"
                            }
                            {% endparse_json %}
                            <ins-button label="Remove" icon="icon-trash-2" size="small" class="cart-remove-btn" data='{{ remove_item }}' ></ins-button>
                            
                        </div> 
                    </div>        
                </div>                   
                <div class="spacer x-large"></div>
            </div>  
            
        {%- endfor -%}
        
        </div>
    </div>
    <ins-loader
        id="shopping-cart-loader"
        class="hide"
        state-title="" 
        state-icon="processing" 
        state-message="Loading">
    </ins-loader>
{%- else -%}

    <div id="shopping-cart-list" class="shopping-cart grid-x grid-padding-x grid-padding-y">
        <div class="small-12 cell">
            <div class="empty-box">
                <span>Your cart is empty.</span>
                <div class="spacer"></div>
                <a href="/products" aria-label="Go to shop">
                    <ins-button type="button" label="Go to shop" solid aria-hidden="true"></ins-button>
                </a>
            </div>
        </div>
    </div>

{%- endif -%}