---
metadata: {
    partial_name: 'Ecommerce | Blocks | New Arrivals'
}
---

{% comment %} This partial is used in the app-portal {% endcomment %}

{% graphql products = "modules/ecommerce/products/get_products", size: 8 | dig: 'items','results' %}

{% if products.size > 0 %}

    {% graphql all_categories = 'modules/ecommerce/categories/get_categories' | dig: 'items','results'  %}
    {% comment %} This export will be used in 'Whats Hot' block to eliminate the need to fetch the categories again {% endcomment %}
    {% export all_categories %}

    {% comment %} Card enrichment (tags, rating, sold) — batched once, reused across the 3 carousels {% endcomment %}
    {%- include 'modules/ecommerce/products/enrich_cards', products: products -%}
    {%- assign cf_rows = context.exports.cf_rows -%}
    {%- assign review_rows = context.exports.review_rows -%}
    {%- assign sold_rows = context.exports.sold_rows -%}

<section class="wrapper">
    <div class="spacer xxxx-large"></div>
    <div class="product-carousel is-loading">

        {%- include 'modules/ecommerce/blocks/carousel_skeleton' -%}

        <!-- desktop carousel -->
        <ins-carousel
            id="newArrivalsCarouselDesktop"
            class="newArrivalsCarousel carouselDesktop show-for-large"
            layout="1"
            per-page="4"
            no-pagination=true
            bind-to="newArrivalCardsDesktop">

            <h2 class="heading-4">New arrivals</h2>
            <div class="spacer xx-large"></div>
            <div id="newArrivalCardsDesktop" class="product-cards">
                {% for product in products %}
                    {% include "modules/ecommerce/products/product_card", product: product, all_categories: all_categories, cf_rows: cf_rows, review_rows: review_rows, sold_rows: sold_rows, heading_level: 'h3' %}
                {% endfor %}
            </div>
            
        </ins-carousel>
        <!-- desktop carousel -->

        <!-- tablet carousel -->
        <ins-carousel 
            id="newArrivalsCarouselTablet"
            class="newArrivalsCarousel carouselTablet show-for-medium-only"
            layout="1"
            per-page="3"
            no-pagination=true
            bind-to="newArrivalCardsTablet">

            <div class="grid-container">
                <div class="grid-x">
                    <h2 class="heading-4">New arrivals</h2>     
                </div>
            </div>

            <div class="spacer xx-large"></div>
            <div id="newArrivalCardsTablet" class="product-cards">
                {% for product in products %}
                    {% include "modules/ecommerce/products/product_card", product: product, all_categories: all_categories, cf_rows: cf_rows, review_rows: review_rows, sold_rows: sold_rows, heading_level: 'h3' %}
                {% endfor %}
            </div>
        </ins-carousel>
        <!-- tablet carousel -->

        <!-- mobile carousel -->
        <div class="wrapper">
            <ins-carousel 
                id="newArrivalsCarouselMobile"
                class="newArrivalsCarousel carouselMobile show-for-small-only"
                layout="1"
                per-page="1"
                no-pagination=true
                bind-to="newArrivalCardsMobile">
                
                <h2 class="heading-4">New arrivals</h2>

                <div class="spacer"></div>
                <div id="newArrivalCardsMobile" class="product-cards">
                    {% for product in products %}
                        {% include "modules/ecommerce/products/product_card", product: product, all_categories: all_categories, cf_rows: cf_rows, review_rows: review_rows, sold_rows: sold_rows, heading_level: 'h3' %}
                    {% endfor %}
                </div>
            </ins-carousel>
        </div>
        <!-- mobile carousel -->

    </div>
    <div class="spacer xxxx-large"></div>
</section>

<script>
var newArrivalsCarousel = document.querySelectorAll('.newArrivalsCarousel');
var showAllLink = {};

function newArrivalsReveal() {
    var wrap = document.querySelector('#newArrivalsCarouselDesktop')
        && document.querySelector('#newArrivalsCarouselDesktop').closest('.product-carousel');
    if (wrap) wrap.classList.remove('is-loading');
}

newArrivalsCarousel.forEach(carousel => {
    var carouselID = carousel.id;
    carousel.addEventListener('didLoad', event => {
        // Carousel has hydrated — drop the skeleton overlay.
        newArrivalsReveal();
        var carouselCtrlBtns = document.querySelector(`#${carouselID} .ins-carousel_ctrl-btns`);
        if(carouselCtrlBtns && showAllLink[carouselID] !== true){
            var newLink = document.createElement('a');
                newLink.href = "/products";
                newLink.textContent = "Shop all";
                newLink.className = "shop-all-link";
            carouselCtrlBtns.appendChild(newLink);
            showAllLink[carouselID] = true;
        }
    });
});

// Safety net: never leave the skeleton up if didLoad doesn't fire.
setTimeout(newArrivalsReveal, 4000);
</script>
{% endif %}