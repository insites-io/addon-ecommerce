---
metadata: {
    partial_name: 'Ecommerce | Checkout | Validate Discsount Code'
}
---
{% comment %}
payload: {
    discount_code: String!
    type: String!              ## 'add' when applying a new code; blank on re-validate
}
## contact_uuid is resolved server-side (get_user_uuid), not taken from payload.
## check_duplicates / delete_invalid are derived from type, not taken from payload.
## total_cart_value (for the minimum_cart_value check) is computed server-side from
## the cart, not taken from payload.
{% endcomment %}
{% comment %} 
    This partial is used to validate discount code for:
    - Adding discount code
    - Order summary in checkout/payment to re-validate the discounts before payment
{% endcomment %}


{%- comment -%} Resolve the cart owner server-side. Never trust payload.contact_uuid:
    this partial is reached from the public validate-discount-code endpoint, and a
    client-supplied uuid would let a caller apply/validate discounts against another
    users cart. get_user_uuid returns the logged-in members uuid or the guests session
    uuid — the same value the checkout order-summary caller already passes. {%- endcomment -%}
{%- function contact_uuid = 'modules/ecommerce/user/get_user_uuid' -%}
{%- assign discount_code = payload.discount_code | default: blank -%}
{%- assign type = payload.type | default: blank -%}
{%- comment -%} Derive the duplicate check from type; never trust a client flag. When
    adding a code we must reject one already in the cart — otherwise a tampered
    check_duplicates=false lets the same code be applied twice (percentage codes are
    not de-duped in compute_order_summary, so they would stack). {%- endcomment -%}
{%- comment -%} Both flags below are derived from type, never trusted from the client.
    check_duplicates: reject a code already in the cart when adding, so a tampered
    false cannot apply the same code twice (percentage codes are not de-duped in
    compute_order_summary, so they would stack).
    delete_invalid: auto-remove an expired/disabled code that is still in the cart.
    This runs on the re-validate pass (type != add) and is what stops an expired code
    from applying at checkout; deriving it guarantees the cleanup regardless of input. {%- endcomment -%}
{%- assign check_duplicates = false -%}
{%- assign delete_invalid = true -%}
{%- if type == 'add' -%}
    {%- assign check_duplicates = true -%}
    {%- assign delete_invalid = false -%}
{%- endif -%}
{%- assign is_valid = true -%}
{%- assign is_duplicate = false -%}


{% comment %} Step 1: Check if code exist {% endcomment %}
{% if discount_code and discount_code != blank %}
    {% graphql discount = "modules/ecommerce/discount/get_discount_by_code",
        discount_code: discount_code, status: 'enabled' | dig: 'items' | dig: 'results' | first %}
{% endif %}    


{% if discount.uuid %}

    {% comment %} Step 2-A: If valid, check if code is already been used to avoid duplicate{% endcomment %}
    {%- if check_duplicates -%}
        {%- if contact_uuid != '' and contact_uuid != blank -%}
            {% comment %} Get cart first to get cart_uuid {% endcomment %}
            {% graphql user_cart = 'modules/ecommerce/carts/get_cart', 
                contact_uuid: contact_uuid | dig: 'items','results' | first %}
            {% if user_cart.uuid %}
                {% graphql current_codes = 'modules/ecommerce/carts/get_cart_discount',
                        cart_uuid: user_cart.uuid, discount_code_uuids: discount.uuid
                        | dig: 'items','results' %}      
                {%- if current_codes.size > 0 -%} 
                    {% assign is_duplicate = true %}
                {%- endif -%}
            {% endif %}
        {%- endif -%}
    {%- endif -%}


    {%- if is_duplicate -%}

        {%- assign message = "Discount code has already been applied." -%}
        {%- assign is_valid = "duplicate" -%}
        
    {%- else -%}
    

        {% comment %} Step 3.1: If valid, validate if discount code # of uses has not been reached {% endcomment %}        
        {%- if discount.usage_count >= discount.usage_limit  -%}
            {% assign message = "Sorry, the discount code's maximum uses has been reached." %}
            {% assign is_valid = "limited use" %}
        {%- endif -%}
        

        {% comment %} Step 3.2: If valid, validate if discount code # of uses per user has not been reached {% endcomment %}  
        {%- if contact_uuid != '' -%}
            {%- assign order_contact_email = context.session.contact_email | default: context.current_user.email | default: '' -%}
            {%- if order_contact_email != '' and order_contact_email != blank -%}
                {% graphql used_discounts_query = 'modules/ecommerce/orders/get_order_discounts',
                        order_contact_email: order_contact_email, discount_code_uuids: discount.uuid
                        | dig: 'items','results' %}
                
                {%- comment -%} Filter results to only count order_discounts where the order belongs to this contact_email {%- endcomment -%}
                {%- assign used_discounts_count = 0 -%}
                {%- for order_discount in used_discounts_query -%}
                    {%- if order_discount.order and order_discount.order.order_contact_email == order_contact_email -%}
                        {%- assign used_discounts_count = used_discounts_count | plus: 1 -%}
                    {%- endif -%}
                {%- endfor -%}

                {%- if used_discounts_count >= discount.usage_limit_per_user  -%}
                    {% assign message = "Sorry, you have reached the limit of using this discount code." %}
                    {% assign is_valid = "limited use per user" %}
                {%- endif -%}
            {%- endif -%}
        {%- endif -%}
        

        {% comment %} Step 3.3: enforce the discounts minimum cart value. Compute the cart
           subtotal server-side (never trust a client-supplied total) by summing price*qty
           over the cart items via cart_item_details — the same gross basis that
           compute_order_summary gates minimum_cart_value on at checkout. Computed lazily,
           only when the discount actually has a minimum. {% endcomment %}
        {% if discount.minimum_cart_value and discount.minimum_cart_value > 0 %}
            {% liquid
                assign total_cart_value = 0
                graphql min_check_cart = 'modules/ecommerce/carts/get_cart', contact_uuid: contact_uuid | dig: 'items','results' | first
                assign min_check_items = min_check_cart.cart_items
                assign min_check_uuids = min_check_items | array_map: 'product_uuid' | array_flatten
                graphql min_check_products = 'modules/ecommerce/products/get_cart_products', uuid: min_check_uuids, size: min_check_items.size | dig: 'items','results'
            %}
            {% for item in min_check_items %}
                {% include 'modules/ecommerce/carts/cart_item_details', products: min_check_products, item: item %}
                {% assign total_cart_value = total_cart_value | plus: context.exports.cart.item_total_price %}
            {% endfor %}
            {% if total_cart_value < discount.minimum_cart_value %}
                {% capture message %}Your cart total must be at least {{ discount.minimum_cart_value }}. Please add more items.{% endcapture %}
                {% assign is_valid = "minimum_cart_value did not meet" %}
            {% endif %}
        {% endif %}


        {% comment %}Step 4: If discount code is still valid, continue other validation checks {% endcomment %}
        {%- if is_valid == blank or is_valid == "" or is_valid == true  -%}

            {% comment %} Step 4-1: If valid, check if cart applies to any items within the cart item{% endcomment %}                

            {% if discount.applicable_to == 'products' and discount.is_applicable_to_all_products == true %}
                {%- assign is_valid = true -%}
            {% elsif discount.applicable_to == 'categories' and discount.is_applicable_to_all_categories == true %}
                {%- assign is_valid = true -%}
            {% else %}

                {% comment %} Get user cart {% endcomment %}
                {%- if contact_uuid != '' and contact_uuid != blank -%}
                    {% graphql carts = 'modules/ecommerce/carts/get_cart', 
                        contact_uuid: contact_uuid | dig: 'items','results' | first %}
                {% endif %}

                {% comment %} Get cart product_uuids {% endcomment %}
                {% if carts.cart_items.size > 0 %}                        
                    {% assign cart_product_uuids = carts.cart_items | array_map: 'product_uuid' | array_flatten %}
                {% endif %}                                

                {% comment %} Get cart category_uuids {% endcomment %}
                {% if cart_product_uuids and discount.applicable_to == 'categories' %}
                    {%  liquid                                            
                        graphql products = 'modules/ecommerce/products/get_cart_products', uuid: cart_product_uuids, size: cart_product_uuids.size | dig: 'items','results'
                        assign cart_category_uuids = products | map: "category_uuids" | flatten | array_uniq
                    %}
                {% endif %}


                {% comment %} Check if any of the products in the cart is included in discount_code products  {% endcomment %}
                {% if discount.applicable_to == 'products' %}
                    {% assign product_matched = discount.product_uuids | array_intersect: cart_product_uuids %}
                {% elsif discount.applicable_to == 'categories' %}
                    {% assign product_matched = discount.category_uuids | array_intersect: cart_category_uuids %}
                {% endif %}

                {%- if product_matched and product_matched.size > 0 -%}
                    {%- assign is_valid = true -%}
                {% else %}
                    {%- assign is_valid = false -%}
                {% endif %}

            {% endif %}

            {%- if is_valid == true -%}
                {% comment %} Step 4-A: If valid, save discount code {% endcomment %}
                {%- assign message = "Discount code has been applied." -%}
               
                {% comment %} Update cart, add new discount_code_uuid {% endcomment %}
                 {% if contact_uuid != '' and contact_uuid != blank and type == 'add' %}
                    {% include 'modules/ecommerce/discounts/update_discount', 
                        user_uuid: contact_uuid,
                        type: 'add', 
                        discount_uuid: discount.uuid %}                                     
                {% endif %}

            {%- else -%}
                {% comment %} Step 4-B: Else invalid, return error & delete from 'cart_discount_code' {% endcomment %}
                {% assign message = "There are no products in your cart is eligible for this discount code." %}
                {% assign is_valid = "no products" %}
            {%- endif -%}

        {%- endif -%}
        
    {%- endif -%}
{% else %}
  {% comment %} Step 2-B: Discount code exist, but disabled / expired / not yet active. {% endcomment %}
  {% comment %} Return state true with discount code's error message {% endcomment %}
  {% assign message = "Sorry, that discount code is not valid. Please check the code has been entered correctly and is within the validation period." %}
  {% assign is_valid = "invalid / expired" %}
{% endif %}


{%- comment -%} ==== API RESPONSE ==== {%- endcomment -%}
{%- comment -%}Status code 400: API or GraphQL error{%- endcomment -%}
{%- if discount == blank or discount == '' %}
    {%- assign status = 400 -%}
    {%- assign message = "Discount code is not found or has been deleted." -%}
    {%- assign is_valid = "not found" -%}
{%- endif -%}


{% comment %} 
    Steps taken in the Order Summary to list and compute discounts.
     - Auto delete invalid discount_code_uuid from modules/insites_ecommerce/cart_discount table
{% endcomment %}
{% assign deleted_item = 0 %}
{%- if delete_invalid == true and is_valid != true and discount_code and discount_code != '' -%}
    {% comment %} Get all the discounts whatever the status is {% endcomment %}
    {% graphql discount = "modules/ecommerce/discount/get_discount_by_code",
        discount_code: discount_code, status: '' | dig: 'items','results' | first %}

    {% comment %} Delete the discount_code from user's cart {% endcomment %}
    {% if discount.status != 'enabled' %}
        {%- include 'modules/ecommerce/discounts/update_discount', 
                user_uuid: contact_uuid,
                type: 'remove',
                discount_uuid: discount.uuid -%}
        {% log "Error: Discount code invalid, discount entry has been deleted " %}
        {% assign deleted_item = 1 %}
    {% endif %}
{%- endif -%}


{%- parse_json validate_code -%}
{
  "is_valid": "{{ is_valid }}",
  "message": "{{ message }}",
  "deleted_item": {{ deleted_item }}
}
{%- endparse_json -%}


{% liquid return validate_code %}