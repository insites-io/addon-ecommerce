---
metadata: {
    partial_name: 'Ecommerce | Checkout | Compute Order Summary'
}
---
{% comment %}
    Parameters from parent:
        - cart (previously user_cart)
        - cart_items (previously carts)
        - products
        - discounts
{% endcomment %}


{% comment %} Initialize Variables {% endcomment %}
{%  liquid
    assign sub_total_amount = 0
    assign sub_total_shipping = 0
    assign sub_total_shipping_discount = 0
    assign combined_base = 0
%}

    {% if cart and cart_items and products %}
        {% comment %} Do nothing {% endcomment %}
    {% else %}
        {% include 'modules/ecommerce/carts/cart_data', cart, cart_items, products %}
        {% assign cart_data = context.exports.cart_data %}
        {% assign cart = cart_data.cart %}
        {% assign cart_items = cart_data.cart_items %}
        {% assign products = cart_data.products %}
        {% comment %} Map cart_discounts to discounts format for compatibility {% endcomment %}
        {% if cart.cart_discounts %}
            {% assign discounts = cart.cart_discounts %}
        {% else %}
            {% assign discounts = '' | split: ',' %}
        {% endif %}
    {% endif %}


{% comment %} Pass 1: Accumulate display prices, extract pre-tax bases, shipping {% endcomment %}
{% if cart_items.size > 0 %}

    {% for item in cart_items %}

        {% include 'modules/ecommerce/carts/cart_item_details', products, item %}
        {% assign cart = context.exports.cart %}
        {% assign item_total_price = cart.item_total_price %}
        {% assign sub_total_amount = sub_total_amount | plus: item_total_price %}

        {% comment %} Normalize is_on_sale: treat null as false {% endcomment %}
        {% liquid
            if cart.selected_prop.is_on_sale == true
                assign is_on_sale = true
            else
                assign is_on_sale = false
            endif
        %}

        {% comment %} Shipping {% endcomment %}
        {%  liquid
            assign is_free_shipping = cart.selected_prop.is_free_shipping
            if is_free_shipping == true
                assign freight_amount = 0
            else
                assign freight_amount = cart.selected_prop.freight_amount
            endif
            assign sub_freight_amount = freight_amount | times: item.quantity
            assign sub_total_shipping = sub_total_shipping | plus: sub_freight_amount
        %}

        {% comment %} Extract pre-tax base per item (Step 1 of discount algorithm) {% endcomment %}
        {%  liquid
            if cart.selected_prop.is_fixed_tax_amount == true
                assign item_base = item_total_price
            else
                assign tax_rate_pct = cart.selected_prop.tax_amount | plus: 0

                assign is_price_tax_included = false
                if is_on_sale == false and cart.selected_prop.is_tax_included == true
                    assign is_price_tax_included = true
                elsif is_on_sale == true
                    if cart.is_variant == true and cart.selected_prop.is_variant_sale_price_tax_included == true
                        assign is_price_tax_included = true
                    elsif cart.is_variant == false and cart.selected_prop.is_sale_price_tax_included == true
                        assign is_price_tax_included = true
                    endif
                endif

                if is_price_tax_included == true
                    assign tax_divisor = tax_rate_pct | divided_by: 100.00 | plus: 1.00
                    assign item_base = cart.price | divided_by: tax_divisor | times: item.quantity
                else
                    assign item_base = item_total_price
                endif
            endif

            assign combined_base = combined_base | plus: item_base
        %}

        {% comment %} Shipping discounts (per-item; independent of product base) {% endcomment %}
        {% for discount in discounts %}
            {%  liquid
                assign minimum_cart_value = discount.discount.minimum_cart_value | plus: 0 | default: 0
            %}
            {% if sub_total_amount >= minimum_cart_value %}
                {%  liquid
                    assign discount_type = discount.discount_type | default: discount.discount.discount_type | downcase
                    assign discount_value = discount.discount_value | default: discount.discount.discount_value

                    assign shipping_discount = 0
                    if discount_type contains "shipping"
                        if discount_type contains "fix" and is_free_shipping == false
                            assign shipping_discount = discount_value | times: item.quantity
                        elsif discount_type contains "percent" and is_free_shipping == false
                            assign shipping_discount = freight_amount | times: discount_value | divided_by: 100 | times: item.quantity
                        elsif discount_type contains "free_shipping"
                            assign shipping_discount = freight_amount | times: item.quantity
                        endif
                        if shipping_discount > sub_freight_amount
                            assign shipping_discount = sub_freight_amount
                        endif
                        assign sub_total_shipping_discount = sub_total_shipping_discount | plus: shipping_discount
                    endif
                %}
            {% endif %}
        {% endfor %}

    {% endfor %}
{% endif %}


{% comment %}
    Step 3: Total product discount — additive, both applied against original combined_base.
    Fixed discounts applied once; percentage against combined_base (not per-item prices).
{% endcomment %}
{% assign total_product_discount = 0 %}
{% assign used_discounts = '' | split: ',' %}
{% for discount in discounts %}
    {%  liquid
        assign minimum_cart_value = discount.discount.minimum_cart_value | plus: 0 | default: 0
    %}
    {% if sub_total_amount >= minimum_cart_value %}
        {%  liquid
            assign discount_type = discount.discount_type | default: discount.discount.discount_type | downcase
            assign discount_value = discount.discount_value | default: discount.discount.discount_value
        %}
        {% if discount_type == "fixed_amount" %}
            {%  liquid
                assign is_discount_used = used_discounts | array_any: discount.discount_code
                if is_discount_used == false or is_discount_used == blank
                    assign total_product_discount = total_product_discount | plus: discount_value
                    assign used_discounts = used_discounts | array_add: discount.discount_code
                endif
            %}
        {% elsif discount_type == "percentage" %}
            {%  liquid
                assign temp = combined_base | times: discount_value | divided_by: 100
                assign total_product_discount = total_product_discount | plus: temp
            %}
        {% endif %}
    {% endif %}
{% endfor %}

{% comment %} Step 4: Discounted base (floor at 0) {% endcomment %}
{% assign discounted_base = combined_base | minus: total_product_discount %}
{% if discounted_base < 0 %}
    {% assign discounted_base = 0 %}
{% endif %}


{% comment %} Pass 2 / Step 5: Recalculate per-item GST proportionally on discounted base {% endcomment %}
{%  liquid
    assign total_gst = 0
    assign sub_total_tax_included = 0
    assign sub_total_tax_not_included = 0
%}

{% if cart_items.size > 0 and combined_base > 0 %}

    {% for item in cart_items %}

        {% include 'modules/ecommerce/carts/cart_item_details', products, item %}
        {% assign cart = context.exports.cart %}

        {% liquid
            if cart.selected_prop.is_on_sale == true
                assign is_on_sale = true
            else
                assign is_on_sale = false
            endif
        %}

        {%  liquid
            if cart.selected_prop.is_fixed_tax_amount == true
                assign item_gst = cart.selected_prop.tax_amount | times: item.quantity
                assign is_price_tax_included = false
            else
                assign tax_rate_pct = cart.selected_prop.tax_amount | plus: 0

                assign is_price_tax_included = false
                if is_on_sale == false and cart.selected_prop.is_tax_included == true
                    assign is_price_tax_included = true
                elsif is_on_sale == true
                    if cart.is_variant == true and cart.selected_prop.is_variant_sale_price_tax_included == true
                        assign is_price_tax_included = true
                    elsif cart.is_variant == false and cart.selected_prop.is_sale_price_tax_included == true
                        assign is_price_tax_included = true
                    endif
                endif

                if is_price_tax_included == true
                    assign tax_divisor = tax_rate_pct | divided_by: 100.00 | plus: 1.00
                    assign item_base = cart.price | divided_by: tax_divisor | times: item.quantity
                else
                    assign item_base = cart.price | times: item.quantity
                endif

                assign item_discounted_base = item_base | times: discounted_base | divided_by: combined_base
                assign item_gst = item_discounted_base | times: tax_rate_pct | divided_by: 100 | round: 2
            endif

            assign total_gst = total_gst | plus: item_gst

            if is_price_tax_included == true
                assign sub_total_tax_included = sub_total_tax_included | plus: item_gst
            else
                assign sub_total_tax_not_included = sub_total_tax_not_included | plus: item_gst
            endif
        %}

    {% endfor %}

{% endif %}


{% if page_slug == 'shopping-cart' %}
    {% assign sub_total_shipping = 0 %}
    {% assign sub_total_shipping_discount = 0 %}
{% endif %}

{% assign effective_shipping = sub_total_shipping | minus: sub_total_shipping_discount %}
{% if effective_shipping < 0 %}
    {% assign effective_shipping = 0 %}
{% endif %}

{% assign total_discount = total_product_discount | plus: sub_total_shipping_discount %}

{% comment %} Step 6: Subtotal {% endcomment %}
{% assign subtotal = discounted_base | plus: total_gst | plus: effective_shipping %}

{% comment %} Step 7: Processing fee {% endcomment %}
{% assign processing_fee = subtotal | times: 0.017 | round: 2 %}

{% comment %} Step 8: Grand total (Stripe minimum $1.00) {% endcomment %}
{% assign total_amount = subtotal | plus: processing_fee %}
{% assign is_minimum_charge = false %}
{% if total_amount < 1.00 and total_amount >= 0 %}
    {% assign total_amount = 1.00 %}
    {% assign is_minimum_charge = true %}
{% endif %}


{% comment %} Tax display flag {% endcomment %}
{% if sub_total_tax_not_included != 0 and sub_total_tax_included != 0 %}
    {% assign tax_applied = "both" %}
{% else %}
    {% assign tax_applied = "single" %}
{% endif %}


{% parse_json computed %}
{
    "sub_total_amount": {{ sub_total_amount | default: 0 }},
    "net_subtotal_amount": {{ combined_base | default: 0 }},
    "shipping_amount": {{ sub_total_shipping | default: 0 }},
    "total_discount_amount": {{ total_discount | default: 0 }},
    "processing_fee": {{ processing_fee | default: 0 }},
    "tax_amount": {{ total_gst | default: 0 }},
    "total_amount": {{ total_amount | default: 0 }},
    "sub_total_tax_not_included": {{ sub_total_tax_not_included | times: 1 | default: 0 }},
    "sub_total_tax_included": {{ sub_total_tax_included | times: 1 | default: 0 }},
    "tax_applied": "{{ tax_applied }}",
    "is_minimum_charge": {{ is_minimum_charge | default: false }}
}
{% endparse_json %}

{% export computed %}
