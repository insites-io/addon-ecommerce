---
metadata: {
    partial_name: 'Ecommerce | Checkout | Callback Create Address'
}
---
{%- comment -%}Create address models{%- endcomment -%}
{%- unless form.properties.skip_shipping_address or form.properties.shipping_address_id -%}
    {%- graphql create_address = "modules/ecommerce/user/create_address" 
        source_id: user_id
        source_name: "Users"
        name: ""
        address_1: form.properties.shipping_address_1
        address_2: form.properties.shipping_address_2
        address_3: form.properties.shipping_address_3
        suburb: form.properties.shipping_suburb
        state: form.properties.shipping_state
        country: form.properties.shipping_country
        postcode: form.properties.shipping_postcode -%}
{%- endunless -%}
{%- unless form.properties.skip_billing_address or form.properties.billing_address_id -%}
    {%- graphql create_address = "modules/ecommerce/user/create_address" 
        source_id: user_id
        source_name: "Users"
        name: ""
        address_1: form.properties.billing_address_1
        address_2: form.properties.billing_address_2
        address_3: form.properties.billing_address_3
        suburb: form.properties.billing_suburb
        state: form.properties.billing_state
        country: form.properties.billing_country
        postcode: form.properties.billing_postcode -%}
{%- endunless -%}