---
metadata: {
    partial_name: 'Ecommerce | Checkout | Callback Email Notification'
}
---

{% comment %}  
  Required params from parent:
  - status
  - total_preorder_items
  - data
{% endcomment %}

{%- assign status = status | downcase -%}


{% comment %} Autoresponder / Email notification {% endcomment %}

{% comment %}  
  The cart can be composed of in-stock and pre-order items.
  If the total items in the cart is greater than the total preorder items, then trigger order_success notification.
{% endcomment %}
{% if data.cart.size > total_preorder_items and status == 'success' %} 
  {% log "==== Trigger autoresponder order_success notification ====" %}
  {%- graphql trigger = "modules/ecommerce/system/trigger_email_notification", 
      name: 'modules/ecommerce/order_success', 
      data: data -%}
{% endif %}

{% comment %} 
  Pre-order success email notification
  If there is at least one pre-order item, then trigger pre_order_success notification.
{% endcomment %}
{%- if total_preorder_items > 0 and status == 'success' -%}
  {% log "==== Trigger autoresponder pre_order_success notification ====" %}
  {%- graphql trigger = "modules/ecommerce/system/trigger_email_notification", 
        name: "modules/ecommerce/pre_order_success", 
        data: data -%}
{%- endif -%}


{% comment %} Workflow notification {% endcomment %}
{% if status == 'success' %} 
  {% log  "==== Trigger workflow notification ====" %}
  {%- graphql trigger = "modules/ecommerce/system/trigger_email_notification", 
      name: 'modules/ecommerce/order_success_workflow', 
      data: data -%}
{% endif %}