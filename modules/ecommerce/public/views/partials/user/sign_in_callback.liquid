{% comment %} 
     A guest user may have items in their cart. 
     When they log in, the cart associated with that guest will be carried over to their logged-in account.
{% endcomment %}

{% comment %} 
     Tables involved:
     - Cart: modules/insites_ecommerce/cart
     - Cart Items: modules/insites_ecommerce/cart_item
{% endcomment %}


{% if guest_temp_uuid and guest_temp_uuid != '' %}

     {% comment %} Get the guest cart {% endcomment %}
     {% graphql guest_cart = 'modules/ecommerce/carts/get_cart', contact_uuid: guest_temp_uuid | dig: 'items', 'results' | first %}

     {% comment %} If there is item in the guest cart {% endcomment %}
     {% if guest_cart.cart_items.size > 0 %}

          {% comment %} Get the logged-in user's cart {% endcomment %}
          {% graphql user_cart = 'modules/ecommerce/carts/get_cart', contact_uuid: contact_uuid | dig: 'items', 'results' | first %}
          
          {% comment %} Check first if the user_cart already exists for the logged-in user {% endcomment %}
          {% if user_cart.cart_items.size > 0 %}
               {% comment %} There is an existing cart and cart_item. {% endcomment %}
               
               {% assign user_product_uuids = user_cart.cart_items | map: 'product_uuid' | array_uniq %}
               {% assign user_variant_uuids = user_cart.cart_items | map: 'product_variant_uuid' | array_uniq %}
               {% assign guest_product_uuids = guest_cart.cart_items | map: 'product_uuid' | array_uniq %}
               {% assign guest_variant_uuids = guest_cart.cart_items | map: 'product_variant_uuid' | array_uniq %}
               
               {% comment %} Non-variant product(s) {% endcomment %}
               {% if guest_product_uuids.size > 0 and user_product_uuids.size > 0 %}
                    {% assign new_product_uuids = guest_product_uuids | array_subtract: user_product_uuids  %} 
                    {% assign existing_product_uuids = guest_product_uuids | array_intersect: user_product_uuids  %}              
               {% elsif guest_product_uuids.size > 0 %}
                    {% assign new_product_uuids = guest_product_uuids %}
               {% endif %}

               {% comment %} Variant product(s) {% endcomment %}
               {% if guest_variant_uuids.size > 0 and user_variant_uuids.size > 0 %}
                    {% assign new_variant_uuids = guest_variant_uuids | array_subtract: user_variant_uuids  %}
                    {% assign existing_variant_uuids = guest_variant_uuids | array_intersect: user_variant_uuids  %}
               {% elsif guest_variant_uuids.size > 0 %}
                    {% assign new_variant_uuids = guest_variant_uuids %}
               {% endif %}


               {% comment %} New Non-variant product(s) {% endcomment %}
               {% for product_uuid in new_product_uuids %}
                    {% assign quantity = guest_cart.cart_items | array_detect: product_uuid: product_uuid | dig: 'quantity' %}
                    {%- parse_json cart_item_data -%}
                    {
                         "uuid": "{{ '' | uuid }}",
                         "cart_uuid": "{{ user_cart.uuid }}",
                         "quantity": {{ quantity | default: 1 }},
                         "product_uuid": "{{ product_uuid }}",
                         "product_variant_uuid": ""
                    }
                    {%- endparse_json -%}
                    {%- graphql add_cart_item = 'modules/ecommerce/cart_items/add_cart_item', args: cart_item_data -%}
               {% endfor %}

               {% comment %} Existing Non-variant product(s) {% endcomment %}                                        
               {% comment %} Update existing user cart_item(s), use data from guest cart_item(s) {% endcomment %}
               {% if existing_product_uuids.size > 0 %}
                    {% for product_uuid in existing_product_uuids %}
                         {% assign user_cart_item_id = user_cart.cart_items | array_detect: product_uuid: product_uuid | dig: 'id' %}
                         {% assign item = guest_cart.cart_items | array_detect: product_uuid: product_uuid %}
                         {%- parse_json cart_item_data -%}
                         {
                              "id": {{ user_cart_item_id }},
                              "quantity": {{ item.quantity }},                
                              "product_sku": "{{ item.product_sku }}", 
                              "product_price": {{ item.product_price | advanced_format: '%.2f' | default: 0 }}, 
                              "product_name": "{{ item.product_name }}",                  
                              "tax_amount": {{ item.tax_amount | advanced_format: '%.2f' | default: 0 }},
                              "item_tax": {{ item.item_tax | advanced_format: '%.2f'| default: 0 }},                  
                              "product_price_includes_tax": {{ item.is_product_price_includes_tax | default: false }}, 
                              "tax_type": "{{ item.tax_type }}",
                              "line_item_total": {{ item.line_item_total | advanced_format: '%.2f' | default: 0 }},
                              "sub_total": {{ item.sub_total | advanced_format: '%.2f' | default: 0 }}
                         }
                         {%- endparse_json -%}
                         {%- graphql update_cart_item = 'modules/ecommerce/cart_items/update_cart_item', args: cart_item_data -%}                         
                    {% endfor %}
               {% endif %}


               {% comment %} New Variant product(s) {% endcomment %}
               {% for product_variant_uuid in new_variant_uuids %}
                    {% assign quantity = guest_cart.cart_items | array_detect: product_variant_uuid: product_variant_uuid | dig: 'quantity' %}
                    {%- parse_json cart_item_data -%}
                    {
                         "uuid": "{{ '' | uuid }}",
                         "cart_uuid": "{{ user_cart.uuid }}",
                         "quantity": {{ quantity | default: 1 }},
                         "product_uuid": "",
                         "product_variant_uuid": "{{ product_variant_uuid }}"
                    }
                    {%- endparse_json -%}
                    {%- graphql add_cart_item = 'modules/ecommerce/cart_items/add_cart_item', args: cart_item_data -%}
               {% endfor %}

               {% comment %} Existing Variant product(s) {% endcomment %}                                        
               {% comment %} Update existing user cart_item(s), use data from guest cart_item(s) {% endcomment %}
               {% if existing_variant_uuids.size > 0 %}
                    {% for product_variant_uuid in existing_variant_uuids %}
                         {% assign user_cart_item_id = user_cart.cart_items | array_detect: product_variant_uuid: product_variant_uuid | dig: 'id' %}
                         {% assign item = guest_cart.cart_items | array_detect: product_variant_uuid: product_variant_uuid %}
                         {%- parse_json cart_item_data -%}
                         {
                              "id": {{ user_cart_item_id }},
                              "quantity": {{ item.quantity }},   
                              "product_variant_uuid": "{{ item.product_variant_uuid }}",
                              "product_sku": "{{ item.product_sku }}", 
                              "product_price": {{ item.product_price | advanced_format: '%.2f' | default: 0 }}, 
                              "product_name": "{{ item.product_name }}",                  
                              "tax_amount": {{ item.tax_amount | advanced_format: '%.2f' | default: 0 }},
                              "item_tax": {{ item.item_tax | advanced_format: '%.2f'| default: 0 }},                  
                              "product_price_includes_tax": {{ item.is_product_price_includes_tax | default: false }}, 
                              "tax_type": "{{ item.tax_type }}",
                              "line_item_total": {{ item.line_item_total | advanced_format: '%.2f' | default: 0 }},
                              "sub_total": {{ item.sub_total | advanced_format: '%.2f' | default: 0 }}
                         }
                         {%- endparse_json -%}
                         {%- graphql update_cart_item = 'modules/ecommerce/cart_items/update_cart_item', args: cart_item_data -%}                         
                    {% endfor %}
               {% endif %}


               {% comment %} Delete the guest cart {% endcomment %}
               {% graphql delete_guest_cart = 'modules/ecommerce/carts/delete_cart', id: guest_cart.id %}

               {% comment %} Delete the guest cart items {% endcomment %}
               {% graphql delete_guest_cart_items = 'modules/ecommerce/cart_items/delete_cart_items', cart_uuid: guest_cart.uuid %}
               
          {% elsif user_cart.contact_uuid == contact_uuid %}
               {% comment %} There is an existing cart but NO cart_item. {% endcomment %}

               {% comment %} Update the guest cart_item(s) cart_uuid to the user_cart.uuid {% endcomment %}
               {% graphql update_cart_item_cart_uuids = 'modules/ecommerce/cart_items/update_cart_item_cart_uuids', 
                    current_cart_uuid: guest_cart.uuid, 
                    new_cart_uuid: user_cart.uuid %}

               {% comment %} Delete the guest cart {% endcomment %}
               {% graphql delete_guest_cart = 'modules/ecommerce/carts/delete_cart', id: guest_cart.id %}

          {% else %}
               {% comment %} There is no existing cart for the logged-in user. Replace guest_temp_uuid with contact_uuid {% endcomment %}
               {% graphql update_cart_contact_uuid = 'modules/ecommerce/carts/update_cart_contact_uuid', 
                    contact_uuid: contact_uuid, 
                    guest_uuid: guest_temp_uuid %}
          {% endif %}

     {% endif %}
          
     {% session guest_temp_uuid = null %}
{% endif %}