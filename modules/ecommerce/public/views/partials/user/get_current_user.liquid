{% liquid 
     ## Use sessions if exists, else save to sessions 
     ## This is to avoid multiple calls to the database.  
     if context.session.is_user_data_updated == true or is_user_data_updated == true
          graphql get_current_user = 'modules/ecommerce/account/get_current_user'
          session get_current_user = get_current_user
          session is_user_data_updated = false
     else
          if context.session.get_current_user and context.session.get_current_user != ''
               assign get_current_user = context.session.get_current_user
          else
               graphql get_current_user = 'modules/ecommerce/account/get_current_user'
               session get_current_user = get_current_user
          endif
     endif

     return get_current_user
%}