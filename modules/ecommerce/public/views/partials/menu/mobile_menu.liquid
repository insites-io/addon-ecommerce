---
metadata: {
    partial_name: 'Ecommerce | Menu | Mobile Menu'
}
---

{% comment %} This partial is used in the app-portal {% endcomment %}

{% comment %} Shared category data — fetched once per request, reused by mega_menu {% endcomment %}
{% include 'modules/ecommerce/menu/menu_categories' %}
{% assign featured_categories = context.exports.menu_featured_categories %}
{% assign sub_categories = context.exports.menu_sub_categories %}

<ins-accordion menu>
    <ins-accordion-item class="colorBlack has-subitems" heading="Shop" link="#" open-icon="icon-plus" close-icon="icon-minus" link-target="_self">
        <ins-accordion-link class="colorBlack" label="All" link="/products" link-target="_self"></ins-accordion-link>
        <ins-accordion-link class="colorBlack" label="New arrivals" link="/products?sort=newest" link-target="_self"></ins-accordion-link>
        <ins-accordion-link class="colorBlack" label="Sale" link="/products?show=sale" link-target="_self"></ins-accordion-link>
        {%- for parent_category in featured_categories -%}
            {%- assign has_sub = false -%}
            {%- for sub_category in sub_categories -%}
                {%- if sub_category.parent_category_uuids contains parent_category.uuid -%}
                    {%- assign has_sub = true -%}
                {%- endif -%}
            {%- endfor -%}

            {%- if has_sub -%}
                <ins-accordion menu>
                    <ins-accordion-item class="colorBlack has-subitems" heading="{{ parent_category.category_name | capitalize }}" link="/products/{{parent_category.slug}}" open-icon="icon-plus" close-icon="icon-minus" link-target="_self">
                        {% for sub_category in sub_categories %}
                            {% if sub_category.parent_category_uuids contains parent_category.uuid %}
                                <ins-accordion-link class="colorBlack" label="{{ sub_category.category_name | capitalize }}" link="/products/{{sub_category.slug}}" link-target="_self"></ins-accordion-link>
                            {% endif %}
                        {% endfor %}
                    </ins-accordion-item>
                </ins-accordion>
            {%- else -%}
                <ins-accordion-link class="colorBlack" label="{{ parent_category.category_name | capitalize }}" link="/products/{{parent_category.slug}}" link-target="_self"></ins-accordion-link>
            {%- endif -%}
        {%- endfor -%}
        {% for item in features %} 
            <ins-accordion-link class="colorBlack" label="{{ item.card_title }}" link="/{{ menu.slug }}/{{ item.slug }}" link-target="_self"></ins-accordion-link>
        {% endfor %} 
    </ins-accordion-item>
</ins-accordion>