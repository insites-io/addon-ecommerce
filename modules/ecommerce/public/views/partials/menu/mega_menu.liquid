---
metadata: {
    partial_name: 'Ecommerce | Menu | Mega Menu'
}
---

{% comment %} This partial is used in the app-portal {% endcomment %}

{% comment %} Shared category data — fetched once per request, reused by mobile_menu {% endcomment %}
{% include 'modules/ecommerce/menu/menu_categories' %}
{% assign featured_categories = context.exports.menu_featured_categories %}
{% assign sub_categories = context.exports.menu_sub_categories %}
{% assign product_category_uuids = context.exports.menu_product_category_uuids %}


<ins-modal 
  id="mega-menu"
  class="no-hover-border hide"
  with-backdrop=false light
    value="DATA"
  height="400px"  
  width="100%"
  no-button>
    
  <div class="grid-x">
    <div class="top-categories cell large-3 medium-3">
        <p class="heading">Shop</p>
        <ul>
            <li><a href="/products">All</a></li>
            <li><a href="/products?sort=newest">New arrivals</a></li>
            <li><a href="/products?show=sale">Sale</a></li>
        </ul>
    </div>
    <div class="featured-categories cell large-9 medium-9 grid-x align-justify">

        {%- comment -%} Track subcategories already rendered so one shared across featured parents shows once. {%- endcomment -%}
        {% assign rendered_subs = '' | split: ',' %}
        {% for parent_category in featured_categories %}
            {%- comment -%} Only show categories that have products. {%- endcomment -%}
            {% if product_category_uuids contains parent_category.uuid %}
            <div class="wrap">
                <a class="heading" href="/products?categories={{parent_category.slug}}">{{ parent_category.category_name | capitalize }}</a>
                <ul class="subcat">
                    {% for sub_category in sub_categories %}
                        {% if sub_category.parent_category_uuids contains parent_category.uuid and product_category_uuids contains sub_category.uuid %}
                            {% unless rendered_subs contains sub_category.uuid %}
                                <li><a href="/products?categories={{sub_category.slug}}">{{ sub_category.category_name | capitalize }}</a></li>
                                {% assign rendered_subs = rendered_subs | array_add: sub_category.uuid %}
                            {% endunless %}
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
        {% endfor %}
    </div>
  </div>

</ins-modal>

<script>
  var megaMenu = document.getElementById('mega-menu');
  var megaMenuBtn = document.getElementById('mega-menu-btn');

  // Expose the trigger's disclosure state to assistive tech (the button opens
  // the mega-menu dialog). Set once, then kept in sync on open/close below.
  if (megaMenuBtn) {
    megaMenuBtn.setAttribute('aria-haspopup', 'dialog');
    megaMenuBtn.setAttribute('aria-controls', 'mega-menu');
    megaMenuBtn.setAttribute('aria-expanded', 'false');
  }

  megaMenu.addEventListener('didLoad', () => {
    megaMenu.classList.remove('hide');
  });

  megaMenuBtn.addEventListener('insClick', () => {
    megaMenu.open();
    megaMenuBtn.classList.add('show-modal');
    megaMenuBtn.setAttribute('aria-expanded', 'true');
  });

  megaMenu.addEventListener('insClose', () => {
    megaMenuBtn.classList.remove('show-modal');
    megaMenuBtn.setAttribute('aria-expanded', 'false');
  });

  // Close mega menu on scroll (also used in app-portal template)
  window.addEventListener('scroll', function () {
    setTimeout(function () {
      if (megaMenu && typeof megaMenu.close === 'function') {
        megaMenu.close();
      }
    }, 200); // delay in ms
  });
</script>