---
metadata: {
    partial_name: 'Ecommerce | Carts | Remove to Cart'
}
---
{% liquid 
    if id != '' and id != blank
        ## Do nothing. The id, uuid, and cart_uuid are passed as parameters from parent
    else 
        assign params = context.params
        assign id = params.id
        assign uuid = params.uuid
        assign cart_uuid = params.cart_uuid
    endif
%}    


{%- if id and uuid != '' and cart_uuid != '' -%}

    {% comment %} Ensure that the parameters passed match the item targeted for deletion. {% endcomment %}
    {%- parse_json data -%}
    {
        "id": {{ id | default: 0 }},
        "uuid": "{{ uuid }}",
        "cart_uuid": "{{ cart_uuid }}"
    }
    {%- endparse_json -%}
    {%- graphql get_cart_item = 'modules/ecommerce/cart_items/get_cart_item', args: data | dig: 'items','results' | first -%}
    
    {%- if get_cart_item.id -%}
        {%- graphql response = 'modules/ecommerce/cart_items/delete_cart_item', id: id | dig: 'record_delete' -%}

        {% comment %} Update the 'cart' table timestamp to refresh the cache. {% endcomment %}
        {% assign now = 'now' | date: "%Y-%m-%dT%H:%M:%S.%LZ" %}
        {%- graphql update_cart_timestamp = 'modules/ecommerce/carts/update_cart_timestamp', 
                uuid: cart_uuid, now: now | dig: 'items' -%}
               
    {%- else -%}
        {% assign response = 'Unauthorized' %}
    {%- endif -%}

{%- else -%}
    {% assign response = 'Unauthorized' %}
{%- endif -%}


{%- if print == true -%}
    {{- response -}}
    {%- response_status 200 -%}
{%- endif -%}