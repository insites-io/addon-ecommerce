---
metadata: {
    partial_name: 'Ecommerce | Products | Main Filters'
}
---
{% assign params = context.params %}

{%- comment -%}
    Admin-managed synonyms for the predictive search dropdown.
    Built into a { "term": ["syn", ...] } map and exposed to predictive-search.js.
    Falls back to the script's built-in defaults when no rows exist.
{%- endcomment -%}
{%- graphql product_synonyms = 'modules/ecommerce/products/get_product_search_synonyms' -%}
{%- assign synonym_rows = product_synonyms.items.results -%}
{%- if synonym_rows.size > 0 -%}
    {%- capture synonym_json -%}
    {
    {%- for row in synonym_rows -%}
        {%- assign term = row.term | strip | downcase | replace: '"', '' -%}
        {%- assign synonym_parts = row.synonyms | split: ',' -%}
        "{{ term }}": [
        {%- for part in synonym_parts -%}
            "{{ part | strip | downcase | replace: '"', '' }}"{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
        ]{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
    }
    {%- endcapture -%}
    <script>window.PRODUCT_SEARCH_SYNONYMS = {{ synonym_json }};</script>
{%- endif -%}

        <div class="filter">
            <ins-input
                id="filter-keyword"
                class="filter-keyword"
                icon-event
                title="Search products"
                placeholder="Search"
                value="{{ params.keyword | default: '' }}"
                field="search"
                icon="icon-search1"
                size="large">
            </ins-input>            
            <div class="spacer"></div>

            <div class="grid-x">
                <div class="main-filters large-auto small-12 cell grid-x flex-container align-justify">
                    <div class="main-filter-by align-middle grid-x large-10 medium-12 small-12">                                               
                        {%  liquid
                            if params.sort == 'price-ascending'
                                assign sortText = 'Price: Low-High'
                            elsif params.sort == 'price-descending'
                                assign sortText = 'Price: High-Low'
                            else 
                                assign sortText = 'Newest'
                            endif
                        %}
                        <div class="show-for-small-only spacer x-small cell"></div>
                        <ins-button-select 
                            id="sortSelect"
                            label="Sort by" 
                            placeholder="{{ sortText }}" 
                            small>
                            <ins-button-select-option label="Newest" value="newest" {% if params.sort == "newest" %}activated{% endif %}></ins-button-select-option>
                            <ins-button-select-option label="Price: High-Low" value="price-descending" {% if params.sort == "price-descending" %}activated{% endif %}></ins-button-select-option>
                            <ins-button-select-option label="Price: Low-High" value="price-ascending" {% if params.sort == "price-ascending" %}activated{% endif %}></ins-button-select-option>
                        </ins-button-select>
                    </div>
                    <div class="main-filter-views align-middle align-right grid-x hide-for-small-only">
                        <div><p class="form-label pr-8 text">View:</p></div>
                        <ins-button id="view-grid-btn" icon="icon-grid" color="white" size="normal" label="" title="Grid view" class="view-button active"></ins-button>
                        <ins-button id="view-list-btn" icon="icon-list" color="white" size="normal" label="" title="List view" class="view-button"></ins-button>
                    </div>
                </div>
            </div>
        </div>        