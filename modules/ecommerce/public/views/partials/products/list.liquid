---
metadata: {
    partial_name: 'Ecommerce | Products | List'
}
---
{% comment %} 
    Variable passed from parent page
    - all_categories
{% endcomment %}

{% assign params = context.params %}


{%- comment -%} Filter params {%- endcomment -%}
{%- assign page_num = params.page | default: 1 | plus: 0 -%}
{%- assign per_page = params.per_page | default: 9 | plus: 0 -%}
{%- assign show = params.show | default: "all" -%}
{%- assign keyword = params.keyword | default: "" -%}
{%- assign min_price = params.min_price | default: "" -%}
{%- assign max_price = params.max_price | default: "" -%}

{%- comment -%} Advanced sidebar filters {%- endcomment -%}
{%- assign brands_param = params.brands | default: "" -%}
{%- assign availability = params.availability | default: "" -%}
{%- liquid
    assign stock_gt = ""
    assign stock_lte = ""

    if show == "in-stock"
        assign stock_gt = "0"
    endif

    assign avail_instock = false
    assign avail_outstock = false
    if availability contains "in-stock"
        assign avail_instock = true
    endif
    if availability contains "out-of-stock"
        assign avail_outstock = true
    endif

    if avail_instock and avail_outstock
        comment # both selected = no stock constraint
        endcomment
    elsif avail_instock
        assign stock_gt = "0"
    elsif avail_outstock
        assign stock_lte = "0"
    endif
-%}


{%- comment -%} Sorting {%- endcomment -%}
{%- assign sort = params.sort | default: "newest" -%}
{%- if sort == "newest" -%}
    {%- parse_json sort_by -%}
    { "created_at": { "order": "DESC" } }
    {%- endparse_json -%}
{%- elsif sort == "price-ascending" -%}
    {%- parse_json sort_by -%}
    [{ "properties": [
        { "name" : "effective_price", "order": "ASC" },
        { "name" : "name", "order": "ASC" }
    ]
    }]
    {%- endparse_json -%}
{%- elsif sort == "price-descending" -%}
    {%- parse_json sort_by -%}
    [{ "properties": [ 
        { "name" : "effective_price", "order": "DESC" },
        { "name" : "name", "order": "ASC" } 
    ] 
    }]
    {%- endparse_json -%}
{%- endif -%}


{% comment %} Filter by Categories {% endcomment %}
{%  liquid
    assign param_cat = params.category | strip
    assign param_slug2 = params.slug2 | strip

    comment # Legacy single category from the path (/products/{slug2}) or ?category= — also scopes the facet counts.
    endcomment
    if param_cat != ''
        assign category_uuids = all_categories | array_detect: slug: param_cat | dig: 'uuid' | split: ','
        assign category_name = all_categories | array_detect: slug: param_cat | dig: 'category_name'
    elsif param_slug2 != ''
        assign category_uuids = all_categories | array_detect: slug: param_slug2 | dig: 'uuid' | split: ','
        assign category_name = all_categories | array_detect: slug: param_slug2 | dig: 'category_name'
    endif

    comment # Multi-select categories from the sidebar checkboxes (?categories=slug1,slug2).
    # Resolve each slug to a uuid and union with the legacy selection for the product query.
    endcomment
    assign filter_cat_uuids = ''
    if category_uuids.size > 0
        assign filter_cat_uuids = category_uuids | join: ','
    endif
    assign param_categories = params.categories | default: '' | strip
    if param_categories != ''
        assign sel_cat_slugs = param_categories | split: ','
        for s in sel_cat_slugs
            assign s_uuid = all_categories | array_detect: slug: s | dig: 'uuid'
            if s_uuid and s_uuid != ''
                if filter_cat_uuids != ''
                    assign filter_cat_uuids = filter_cat_uuids | append: ',' | append: s_uuid
                else
                    assign filter_cat_uuids = s_uuid
                endif
            endif
        endfor
    endif
    assign filter_category_uuids = filter_cat_uuids | split: ',' | uniq
%}


{%- comment -%} Step build parameters to pass to GraphQL {%- endcomment -%}
{%- parse_json filters -%}
{
    "page": {{page_num}},
    "size": {{per_page}},
    "keyword": "{{keyword}}",
    "sort":{{ sort_by | json }}
}
{%- endparse_json -%}

{%- comment -%} keywords {%- endcomment -%}
{%- if keyword and keyword != '' -%}
    {%- parse_json keyword_arr -%}["{{ keyword }}"]{%- endparse_json -%}
    {%- assign filters = filters | add_hash_key: 'keywords', keyword_arr -%}
{%- endif -%}

{%- comment -%} Multi-select categories {%- endcomment -%}
{%- if filter_category_uuids.size > 0 -%}
    {%- assign filters = filters | add_hash_key: 'category_uuids', filter_category_uuids -%}
{%- endif -%}

{%- comment -%} Multi-select brands {%- endcomment -%}
{%- if brands_param != '' -%}
    {%- assign brands_arr = brands_param | split: ',' -%}
    {%- assign filters = filters | add_hash_key: 'brands', brands_arr -%}
{%- endif -%}

{%- comment -%} Price range {%- endcomment -%}
{%- if min_price != '' -%}
    {%- assign filters = filters | add_hash_key: 'min_price', min_price -%}
{%- endif -%}
{%- if max_price != '' -%}
    {%- assign filters = filters | add_hash_key: 'max_price', max_price -%}
{%- endif -%}

{%- comment -%} Filter by: show {%- endcomment -%}
{%- if show == "sale" -%}
    {%- assign filters = filters | add_hash_key: 'is_on_sale', true -%}
{%- endif -%}

{%- comment -%} Availability (in / out of stock) {%- endcomment -%}
{%- if stock_gt != '' -%}
    {%- assign filters = filters | add_hash_key: 'not_number', stock_gt -%}
{%- endif -%}
{%- if stock_lte != '' -%}
    {%- assign filters = filters | add_hash_key: 'stock_lte', stock_lte -%}
{%- endif -%}



{% comment %} Build filter options + counts from the enabled catalog (category/keyword context) {% endcomment %}
{%- parse_json facet_args -%}
{
    "keyword": "{{ keyword }}"
    {%- if keyword and keyword != '' -%},"keywords": ["{{ keyword }}"]{%- endif -%}
    {%- if category_uuids.size > 0 -%},"category_uuids": {{ category_uuids }}{%- endif -%}
}
{%- endparse_json -%}
{%- graphql product_facets = 'modules/ecommerce/products/get_product_facets', args: facet_args -%}

{% comment %} 
    Note: product total_entries and results must be in separate query for optimal performance 
{% endcomment %}

{% comment %} Get products total_entries {% endcomment %}
{%- graphql products_total_entries = 'modules/ecommerce/products/search_products_total_entries', args: filters -%}

{% comment %} Get products results {% endcomment %}
{%- graphql products = 'modules/ecommerce/products/search_products', args: filters -%}


{% comment %} Title Heading {% endcomment %}
<div class="grid-x grid-padding-x">
    <div class="small-10 small-offset-1 cell text-center">
        {%- if keyword and keyword != blank -%}
            <h1 class="heading-1 weight-normal">Search result for <br><b>"{{ keyword }}"</b></h1>
        {%- else -%}
            {%- if params.slug2 -%}
                <h1 class="heading-1">{{ category_name }}</h1>
            {%- else -%}
                <h1 class="heading-1">All products</h1>
            {%- endif -%}
        {%- endif -%}
        {%- assign product_total = products_total_entries.items.total_entries | default: 0 -%}
        <p class="font-color-sub" data-product-count>{{ product_total }} {% if product_total == 1 %}product{% else %}products{% endif %}</p>
        <div class="spacer xxx-large hide-for-small-only"></div>
        <div class="spacer large show-for-small-only"></div>
    </div>
</div>

<div class="product-list grid-x grid-padding-x  {% if total_cat_child == 0 %} align-center {% endif %}">    
    <div class="large-3 medium-12 small-12 cell">
        
        {% comment %} Filter drawer for Mobile view {% endcomment %}
        <div class="hide-for-large">
            <ins-button label="Filters" icon="icon-sliders" id="mobile-category-button" outlined></ins-button>
            <div class="spacer small"></div>
            <ins-drawer
                custom-width="430px"
                position="right"
                bordered=false
                id="mobile-filter-drawer">
                <div class="wrap">
                    {%- include 'modules/ecommerce/products/sidebar_filters', facets: product_facets.items.results, mode: 'mobile' -%}
                </div>
            </ins-drawer>
        </div>

        {% comment %} Sidebar Filters for Desktop view {% endcomment %}
        <div class="sidebar-categories show-for-large">
            {%- include 'modules/ecommerce/products/sidebar_filters', facets: product_facets.items.results, mode: 'desktop' -%}
        </div>
    </div>
    

    <div class="large-9 medium-12 small-12 cell">
        
        {% include "modules/ecommerce/products/main_filters", filters: filters %}
        
        <div class="spacer"></div>
        
        {% comment %} List grid — AJAX swap target. Contents come from the shared grid partial
           (server render here, /api/products/list-results for filter/search/pagination updates). {% endcomment %}
        <div id="product-grid" class="product-cards products-grid grid-x grid-padding-x grid-padding-y medium-up-3 small-up-1">
            {%- include 'modules/ecommerce/products/grid', products: products.items.results, all_categories: all_categories -%}
        </div>

        <div class="spacer x-large"></div>

        {% include "modules/ecommerce/layout/pagination", data: products_total_entries.items, label: 'Products per page', ajax: true %}

    </div>
</div>