---
metadata: {
    partial_name: 'Ecommerce | Products | Detail'
}
---

{% comment %}  
    Required from parent
    - product
{% endcomment %}
    
{% liquid

    ## Galleries
    assign galleries = '' | split: ','    
    assign gallery_indexes = '{}' | parse_json 
    assign index = 0

    ## Main Product Image
    assign main_image = product.product_image.url | replace: ' ', '%20' | escape | default: ''
    if main_image and main_image != ''
        assign galleries = galleries | array_add: main_image  
        assign index = index | plus: 1
    endif

    ## Gallery_1
    if product.gallery_1.size > 0
        for gallery in product.gallery_1
            assign gallery_url = gallery.file.url | replace: ' ', '%20' | escape | default: ''
            if gallery_url and gallery_url != ''
                assign galleries = galleries | array_add: gallery_url
                assign gallery_indexes = gallery_indexes | add_hash_key: gallery.id, index
                assign index = index | plus: 1
            endif
        endfor
    endif

    ## Gallery_2
    if product.gallery_2.size > 0        
        for gallery in product.gallery_2
            assign galleries = galleries | array_add: gallery.file.url
            assign index = index | plus: 1
        endfor
    endif
    
    
    if product.is_product_variant_enabled
        ## The product has variants
        assign selected_prop = product.variants[0] 
        assign variant_id = selected_prop.id
        assign product_variant_uuid = selected_prop.uuid 
        assign disabledBtn = 'disabled'
        ## Variant Images        
        for variant in product.variants
            if variant.product_image.url
                assign galleries = galleries | array_add: variant.product_image.url
                assign gallery_indexes = gallery_indexes | add_hash_key: variant.id, index
                assign index = index | plus: 1
            endif
        endfor
    else 
        ## The product doesnt have variant
        assign selected_prop = product    
        assign variant_id = null
        assign product_variant_uuid = null    
        assign disabledBtn = ''
    endif

    ## Pricing
    ## Use product details here even if variant is enabled
    include 'modules/ecommerce/products/pricing', product: product
    assign price = context.exports.price
    assign price_strikethrough = context.exports.price_strikethrough
    assign is_tax_included = context.exports.is_tax_included

    ## Highlighted tags (product-level, from product_custom_field) — same chips as the product card
    assign pdp_product_uuids = product.uuid | split: ','
    graphql pdp_cf_rows = 'modules/ecommerce/products/get_products_custom_fields', product_uuids: pdp_product_uuids | dig: 'items', 'results'
    assign product_cf = pdp_cf_rows | where: 'product_uuid', product.uuid | first
    assign product_tags = product_cf.tags

    ## Reviews — approved-review summary (results feed the meta row; review_summary
    ## is reused by the Review tab below). Sold — completed-order line items.
    graphql review_summary = 'modules/ecommerce/reviews/get_review_summary', reviewed_product: product.uuid | dig: 'items'
    graphql pdp_sold_rows = 'modules/ecommerce/order_items/get_products_sold_count', product_uuids: pdp_product_uuids | dig: 'items', 'results'

    ## Rating + sold stats — computed in products/product_rating_sold (shared with the card)
    include 'modules/ecommerce/products/product_rating_sold', review_list: review_summary.results, sold_list: pdp_sold_rows
    assign review_count = context.exports.review_count
    assign avg_rating = context.exports.avg_rating
    assign sold_count = context.exports.sold_count

    ## Stock indicator state is computed inside products/stock_indicator (shared with the card).
    assign low_override = product_cf.low_stock_override

    assign variants = '[]'
%}

<ins-button label="Go back" icon="icon-angle-left" class="inline go-back" onclick=window.history.back();></ins-button>
<div class="spacer"></div>

<div class="product-detail grid-x grid-padding-x">
    <div class="large-7 medium-12 small-12 cell">                
        <div class="gallery">   

            {% comment %} Highlighted tags (from product_custom_field) {% endcomment %}
            {% include 'modules/ecommerce/products/product_tags', tags: product_tags %}


            {% comment %} Out of Stock {% endcomment %}
            {%  liquid 
                assign btnLabel = 'Pre-Order'
                if product.is_product_variant_enabled 
                    ## Initially hide the out-of-stock overlay when a variant is enabled
                    assign hideOutOfStock = 'hide'
                    assign btnLabel = 'Buy now'
                elsif product.stock_level > 0
                    assign hideOutOfStock = 'hide'
                    assign btnLabel = 'Buy now'
                else
                    assign hideOutOfStock = ''
                endif
            %}
            <div id="out-of-stock-overlay" class="out-of-stock {{hideOutOfStock}}"></div>

            {% comment %} Use gallery or product_image {% endcomment %}
            {%- if galleries.size > 0 -%}                  
                <div class="main-gallery variant-gallery">                       
                    <ins-gallery  
                        with-indicator 
                        slidable 
                        slidable-thumbs 
                        thumbnail-layout="slider"
                        id="product-galleries">
                        {%- for gallery in galleries -%}
                            <ins-gallery-image
                                thumbnail="{{ gallery }}"
                                image="{{ gallery }}">
                            </ins-gallery-image>
                        {%- endfor -%}
                    </ins-gallery>
                </div>
            {%- else -%}
                {%- include 'modules/website/layout/placeholder_image', size: 'large' -%}
            {%- endif -%}
        </div>
    </div>

    <div class="large-4 medium-12 small-12 large-offset-1 cell">
        <div class="hide-for-large spacer x-large"></div>

        <div class="grid-y grid-padding-y product-details-column-2">
            {% comment %} Text heading {% endcomment %}
            <div>
                {%- if product.brand_name and product.brand_name != blank -%}
                    <p class="product-brand">{{ product.brand_name }}</p>
                    <div class="spacer x-small"></div>
                {%- endif -%}
                <h1 class="heading-1">{{ product.product_name }}</h1>
                {%- if review_count > 0 or sold_count > 0 -%}
                    <div class="spacer x-small"></div>
                    <div class="product-meta">
                        {%- if review_count > 0 -%}
                            <span class="product-rating">
                                {% include 'modules/ecommerce/reviews/star_rating', rating: avg_rating, size: 16 %}
                                <span class="product-rating__count body-small">({{ review_count }})</span>
                            </span>
                        {%- endif -%}
                        {%- if sold_count > 0 -%}
                            <span class="product-sold body"><span class="product-sold__count">{{ sold_count }}</span> sold</span>
                        {%- endif -%}
                    </div>
                {%- endif -%}
            </div>

            {% comment %} Price {% endcomment %}
            {% if price == '' or price == blank %}
                {% assign hidePrice = 'hide' %}
            {% endif %}
            <div id="pricing-wrap" class="wrap {{hidePrice}}">
                <p id="product-price" class="heading-5-small">{{ price | pricify: 'USD', no_cents_if_whole: false }}</p>
                <p id="regular-product-price" class="strikethrough">{{ price_strikethrough }}</p>
            </div>

            {% comment %} SKU + Short Description {% endcomment %}
            {% if product.sku != '' or product.short_description %}
            <div>
                {% if product.sku != '' %}
                    <p>SKU: <span id="product-sku">{{ product.sku }}</span></p>
                {% endif %}
                {% if product.sku != '' and product.short_description %}
                    <div class="spacer x-small"></div>
                {% endif %}
                {% if product.short_description %}
                    <p>{{ product.short_description }}</p>
                {% endif %}
            </div>
            {% endif %}
                    
            {% comment %} Out of Stock Notice {% endcomment %}
            <div id="out-of-stock-notice" class="out-of-stock-notice {{ hideOutOfStock }}">    
                <p class="bold">Sorry, this product is currently out of stock.</p>                         
                <p>You can secure yours by placing a pre-order now! We will notify you when your pre-order becomes available for delivery.</p>            
            </div>

            {% comment %} Variants {% endcomment %}
            {%- if product.is_product_variant_enabled -%} 
                <div class="grid-y">
                    <div class="small-12 cell">
                        
                        {% comment %} Parse and deduplicate variant options {% endcomment %}
                        {% assign variants = '' | split: ',' %}
                        {%- for variant in product.variants -%}
                            {%  liquid
                                assign item_obj = '' | split: ','
                                assign seen_keys = '' | split: ','
                                for item in variant.product_options
                                    assign item_json = item | parse_json
                                    assign opt_key = item_json.product_option_label | append: '::' | append: item_json.product_option_value
                                    unless seen_keys contains opt_key
                                        assign item_obj = item_obj | array_add: item_json
                                        assign seen_keys = seen_keys | array_add: opt_key
                                    endunless
                                endfor
                                assign variant = variant | add_hash_key: 'options', item_obj
                                assign variants = variants | array_add: variant
                            %}
                        {%- endfor -%}

                        {% if variants.size > 0 %}
                            {% assign first_option_label = '' %}
                            {% assign first_option_values = '' | split: ',' %}

                            {% for variant in variants %}
                                {% if variant.options.size > 0 %}
                                    {% assign first_opt = variant.options[0] %}
                                    {% if first_option_label == '' %}
                                        {% assign first_option_label = first_opt.product_option_label %}
                                    {% endif %}
                                    {% unless first_option_values contains first_opt.product_option_value %}
                                        {% assign first_option_values = first_option_values | array_add: first_opt.product_option_value %}
                                    {% endunless %}
                                {% endif %}
                            {% endfor %}

                            {% assign first_option_label_display = first_option_label | capitalize %}

                            <div id="product-options">
                                <ins-select
                                    id="option-0"
                                    class="variant-select2"
                                    label="{{ first_option_label_display }}"
                                    label-key="{{ first_option_label }}"
                                    placeholder="Select {{ first_option_label_display }}"
                                    error-message="Please select a {{ first_option_label_display }}"
                                    small>
                                    {% for value in first_option_values %}
                                    <ins-select-option label="{{ value }}" value="{{ value }}" ></ins-select-option>
                                    {% endfor %}
                                </ins-select>

                                {% comment %} Dynamic selects will be inserted here {% endcomment %}
                                <div id="next-selects"></div>
                            </div>
                        {% endif %}

                    </div>
                </div>
            {%- endif -%} 
            
            {% comment %} Quantity {% endcomment %}
            <div>
                <p class="form-label">Quantity</p>
                <div class="quantity-row">
                    <ins-input-stepper
                        id="cart-quantity"
                        value="1"
                        step="1" min="1"
                        max="100"
                        small>
                    </ins-input-stepper>
                    {% include 'modules/ecommerce/products/stock_indicator', selected_prop: selected_prop, product: product, low_override: low_override, id: 'stock-indicator' %}
                </div>
            </div>
            {% comment %} Buttons {% endcomment %}            
            {% parse_json add_to_cart_data_old %}
            {
                "detail_page": true,
                "id": "{{ product.id }}",
                "slug": "{{ product.slug }}",
                "product_uuid": "{{ product.uuid }}",
                "product_name": {{ product.product_name | default: '' | strip_html | json }},
                "price": "{{ price | default: 0 }}",
                "product_sku": "{{ product.sku }}",
                "stock_level": "{{ product.stock_level | default: 0 }}",
                "tax_amount": "{{ product.tax_amount | default: 0 }}",
                "is_tax_included": "{{ is_tax_included | default: false }}",
                "is_fixed_tax_amount": "{{ product.is_fixed_tax_amount | default: false }}"
            }
            {% endparse_json %}

            {% parse_json add_to_cart_data %}
            {
                "product_uuid": "{{ product.uuid }}",
                "product_variant_uuid": "{{ product_variant_uuid }}"
            }
            {% endparse_json %}
                              
            <div id="product-details-btn">
                <ins-button id="add-to-cart-btn-{{ add_to_cart_data.id }}"  class="full add-to-cart-btn" data='{{ add_to_cart_data }}' label="{{ btnLabel }}" solid {{disabledBtn}}></ins-button>
                <div class="spacer small"></div>
                <ins-button class="full add-to-cart-btn" label="Add to cart" data='{{ add_to_cart_data }}' icon="icon-shopping-cart" outlined {{disabledBtn}}></ins-button>
            </div>

            {% comment %} Trust messaging — reassurance on shipping, returns & checkout security {% endcomment %}
            <div class="product-trust">
                <ins-accordion>
                    <ins-accordion-item icon="icon-truck" heading="Free shipping" active>
                        <p>Standard ground delivery included at no extra cost.</p>
                    </ins-accordion-item>
                    <ins-accordion-item icon="icon-box" heading="Hassle-free returns">
                        <p>Not a fan? Return it within 30 days for a full refund.</p>
                    </ins-accordion-item>
                    <ins-accordion-item icon="icon-shield" heading="Secure checkout">
                        <p>Your personal and payment data is 100% encrypted and private.</p>
                    </ins-accordion-item>
                </ins-accordion>
            </div>

        </div>

    </div>

    {% comment %} Product tabs: Descriptions + Reviews {% endcomment %}
    <div class="cell product-tabs">
        <div class="spacer x-large"></div>
        {%- function has_profile = "modules/website/layout/check_if_user_has_profile" -%}
        <ins-tab id="product-tabs">
            {%- if product.long_description != blank -%}
            <ins-tab-item label="Descriptions">
                <div class="spacer"></div>
                <div class="body description">{{ product.long_description | html_safe }}</div>
            </ins-tab-item>
            {%- endif -%}
            <ins-tab-item label="Review ({{ review_count }})">
                {% include 'modules/ecommerce/reviews/review_section', product: product, summary: review_summary %}
            </ins-tab-item>
        </ins-tab>
    </div>

    <div class="cell show-for-large spacer xxxx-large"></div>

    <div class="cell">
        {% include 'modules/ecommerce/blocks/you_may_also_like', not_uuid: product.uuid, heading_level: 'h2' %}
    </div>

</div>

{% comment %} Write Review modal. has_profile (fetched in the tabs block above) picks the logged-in vs guest variant; safe to render here as the page cache is keyed by current_user.id. {% endcomment %}
{% include 'modules/ecommerce/reviews/write_review_modal', reviewed_product: product.uuid, has_profile: has_profile %}

<script>
    (function () {
        var reviewModalEl = document.getElementById('review-modal');

        // Any "Write a review" button (summary block + empty state) opens the modal
        var openBtns = document.querySelectorAll('.review-open-btn');
        Array.prototype.forEach.call(openBtns, function (btn) {
            btn.addEventListener('insClick', function () {
                if (reviewModalEl) reviewModalEl.open();
            });
        });

        // Review pagination via AJAX — ins-table (per-page selector + page nav) swaps only the list.
        // Mirrors product-list.js: listen to insPaginationChange, fetch list-results, swap the items.
        var resultsEl = document.getElementById('review-list-results');
        var reviewTable = document.getElementById('insBaseTable');

        if (reviewTable && resultsEl) {
            reviewTable.addEventListener('insPaginationChange', function (event) {
                loadReviewPage(event.detail.pageNumber, event.detail.pageSize);
            });
        }

        function buildReviewSkeleton(count) {
            var row = '<div class="review-item-skeleton">'
                + '<div class="sk-line sk-name"></div>'
                + '<div class="sk-line sk-body"></div>'
                + '<div class="sk-line sk-body short"></div>'
                + '</div>';
            var html = '';
            for (var i = 0; i < count; i++) { html += row; }
            return html;
        }

        async function loadReviewPage(pageNum, pageSize) {
            if (typeof fetch === 'undefined') { window.location.href = '?page=' + pageNum + '&per_page=' + pageSize; return; }
            var productUuid = resultsEl.getAttribute('data-product-uuid');
            // Skeleton placeholders while the page loads
            resultsEl.innerHTML = buildReviewSkeleton(parseInt(pageSize, 10) || 5);
            try {
                var res = await fetch('/api/reviews/list-results?product=' + encodeURIComponent(productUuid) + '&page=' + encodeURIComponent(pageNum) + '&per_page=' + encodeURIComponent(pageSize), {
                    headers: { 'Accept': 'application/json' }
                });
                var data = await res.json();
                resultsEl.innerHTML = data.html;
                // Announce the update to screen readers (the list isn't a live region itself)
                var reviewStatusEl = document.querySelector('[data-review-status]');
                if (reviewStatusEl) { reviewStatusEl.textContent = 'Reviews updated, page ' + data.pageNumber; }
                // Keep the persistent pager in sync
                reviewTable.totalCount = data.totalCount;
                reviewTable.pageNumber = data.pageNumber;
                reviewTable.pageSize = data.pageSize;
                // Reflect page/per_page in the URL without reloading
                var url = new URL(window.location.href);
                url.searchParams.set('page', pageNum);
                url.searchParams.set('per_page', pageSize);
                history.pushState({ reviewPage: pageNum }, '', url.toString());
                var tabsTop = document.getElementById('product-tabs');
                if (tabsTop) tabsTop.scrollIntoView({ behavior: 'smooth', block: 'start' });
            } catch (e) {
                window.location.href = '?page=' + pageNum + '&per_page=' + pageSize;
            }
        }

        // On a full load with ?page in the URL (shared link / no-JS fallback), open the Review tab
        var params = new URLSearchParams(window.location.search);
        if (params.get('page')) {
            var tabEl = document.getElementById('product-tabs');
            if (tabEl) {
                var headers = tabEl.querySelectorAll('.ins-tab-header');
                if (headers.length) headers[headers.length - 1].click();
            }
        }
    })();
</script>

<script>
    const variants = {{ variants }};
    const main_image = "{{ product.product_image.url }}";
    const galleryIndexes = {{ gallery_indexes | default: '[]' }};
    let selected_variant = {
            "product_name": {{ product.product_name | default: '' | strip_html | json }}
        }; 
    
    const productGalleries = document.getElementById('product-galleries');    
    const productSKU = document.getElementById("product-sku");
    const pricingWrap = document.getElementById("pricing-wrap");
    const productPrice = document.getElementById("product-price");
    const regularProductPrice = document.getElementById("regular-product-price");
    const ourOfStockNotice = document.getElementById("out-of-stock-notice");
    const outOfStockOverlay = document.getElementById("out-of-stock-overlay");

    if(variants.length > 0) {
        const nextSelectsWrap = document.getElementById('next-selects');

        // Use pre-parsed and deduplicated options from Liquid (v.options)
        const parsedVariants = variants.map(v => ({ ...v, parsedOptions: v.options }));

        function toTitleCase(str) {
            return str.replace(/\w\S*/g, w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase());
        }

        async function getUserSelections() {
            const selects = document.querySelectorAll('#product-options ins-select, #next-selects ins-select');
            const selections = [];

            for (const select of selects) {
                const label = select.getAttribute('label-key') || select.getAttribute('label');
                const value = await select.getValue();
                if (value) {
                    selections.push({ label, value });
                }
            }

            return selections;
        }

        function findMatchingVariant(selections) {
            return parsedVariants.find(variant =>
                selections.every(selection =>
                    variant.parsedOptions.some(opt =>
                        opt.product_option_label === selection.label &&
                        opt.product_option_value === selection.value
                    )
                )
            );
        }

        function updateSelectionDetails(selectedVariant) {
            if(selectedVariant.id){
                //Identifiers
                selected_variant.id = selectedVariant.id;
                selected_variant.product_variant_uuid = selectedVariant.uuid;
                //SKU
                selected_variant.sku = selectedVariant.sku;
                productSKU.textContent = `${selectedVariant.sku}`;
                //Product Price
                pricingWrap.classList.remove('hide');
                if(selectedVariant.is_on_sale){
                    selected_variant.price = selectedVariant.sale_price;
                    productPrice.textContent = `$${selectedVariant.sale_price}`;
                    regularProductPrice.textContent = `$${selectedVariant.regular_price}`;
                } else {
                    selected_variant.price = selectedVariant.regular_price;
                    productPrice.textContent = `$${selectedVariant.regular_price}`;
                    if (regularProductPrice) {
                        regularProductPrice.textContent = "";
                    }
                }
                //Image
                selected_variant.image = selectedVariant.product_image.url || main_image;
                //Out of Stock Notice
                if(selectedVariant.stock_level < 1){
                    ourOfStockNotice.classList.remove("hide");
                    outOfStockOverlay.classList.remove("hide");
                } else {
                    ourOfStockNotice.classList.add("hide");
                    outOfStockOverlay.classList.add("hide");
                }
                selected_variant.stock_level = selectedVariant.stock_level;
                //product_options
                selected_variant.product_options = selectedVariant.product_options;
                // Sync add-to-cart button data with selected variant
                document.querySelectorAll('#product-details-btn .add-to-cart-btn').forEach(btn => {
                    try {
                        const btnData = JSON.parse(btn.getAttribute('data') || '{}');
                        btnData.product_variant_uuid = selectedVariant.uuid;
                        btn.setAttribute('data', JSON.stringify(btnData));
                    } catch(e) {}
                });
            } else {
                productSKU.textContent = "";
                productPrice.textContent = "$--";
                regularProductPrice.textContent = "";
                ourOfStockNotice.classList.remove("hide");
                outOfStockOverlay.classList.remove("hide");
            }
        }

        function disableAddToCartBtns() {
            document.querySelectorAll('#product-details-btn .add-to-cart-btn').forEach(btn => {
                btn.disabled = true;
            });
        }

        // Render cascading select at given level, filtered by selectedPath
        async function renderSelect(level, selectedPath = []) {

            // Any selection change invalidates the previous complete match
            disableAddToCartBtns();

            // Remove any selects deeper than current level
            [...nextSelectsWrap.children].forEach(child => {
                if (parseInt(child.dataset.level, 10) >= level) {
                    child.remove();
                }
            });

            // Filter variants matching all selected values so far
            const filtered = parsedVariants.filter(variant =>
                selectedPath.every((selected, i) => {
                    const opt = variant.parsedOptions[i];
                    return opt &&
                        opt.product_option_label === selected.label &&
                        opt.product_option_value === selected.value;
                })
            );

            // Find the next option label
            const nextLabel = filtered[0]?.parsedOptions[selectedPath.length]?.product_option_label;

            // No more dropdowns to generate — find and display matching variant
            if (!nextLabel) {
                const selections = await getUserSelections();
                const matchedVariant = findMatchingVariant(selections);

                if (matchedVariant) {
                    console.log('Matching variant:', matchedVariant);
                    updateSelectionDetails(matchedVariant);

                    //Update active view in galleries based on selected variant
                    productGalleries?.activate(galleryIndexes[matchedVariant.id]);

                    //Activate add-to-cart button
                    document.querySelectorAll('#product-details-btn .add-to-cart-btn').forEach(btn => {
                        btn.disabled = false;
                    });
                } else {
                    console.log('No matching variant found');
                }

                return;
            }

            // Collect unique values for next label
            const values = new Set();
            filtered.forEach(v => {
                const opt = v.parsedOptions[selectedPath.length];
                if (opt?.product_option_label === nextLabel) {
                    values.add(opt.product_option_value);
                }
            });

            // Create new ins-select
            const wrapper = document.createElement('div');
            wrapper.dataset.level = level;

            const selectId = `option-${level}`;
            const nextLabelDisplay = toTitleCase(nextLabel);
            wrapper.innerHTML = `
                <div class="spacer"></div>
                <ins-select
                id="${selectId}"
                label="${nextLabelDisplay}"
                label-key="${nextLabel}"
                placeholder="Select ${nextLabelDisplay}"
                validate>
                ${[...values].map(val => `
                    <ins-select-option label="${val}" value="${val}"></ins-select-option>
                `).join('')}
                </ins-select>
            `;

            nextSelectsWrap.appendChild(wrapper);

            // Add listener to new select
            const newSelect = wrapper.querySelector('ins-select');
            newSelect.addEventListener('insValueChange', (e) => {
                const newPath = [...selectedPath, { label: nextLabel, value: e.detail }];
                renderSelect(level + 1, newPath);
            });
        }

        // Add listener to first variant option
        const firstSelect = document.getElementById('option-0');
        const firstLabel = firstSelect.getAttribute('label-key') || firstSelect.getAttribute('label');
        firstSelect.addEventListener('insValueChange', (e) => {
            renderSelect(1, [{ label: firstLabel, value: e.detail }]);
        });
    }
</script>