---
metadata: {
    partial_name: 'Ecommerce | Products | Product Card'
}
---
{%  liquid

    if ordered_item == true
        assign product = item.product
        if item.sku == product.sku
            assign selected_prop = product
        else 
            for variant in product.variants
                if item.sku == variant.sku
                    assign selected_prop = variant
                    assign is_variant = true
                endif
            endfor
        endif
    elsif product.is_product_variant_enabled
        assign class_add_to_cart_btn = ''
        assign selected_prop = product.variant
        assign variant_uuid = product.variant.uuid
    else 
        assign class_add_to_cart_btn = 'add-to-cart-btn'
        assign selected_prop = product
        assign variant_uuid = null
    endif
    

    ## Pricing
    ## Use product details here even if the variant is enabled
    include 'modules/ecommerce/products/pricing', product: product
    assign price = context.exports.price
    assign price_strikethrough = context.exports.price_strikethrough

    ## If price is empty and the item is a variant, then use the variant pricing
    if price == '' or price == blank
        if product.is_product_variant_enabled
            if selected_prop.is_on_sale == true 
                assign price = selected_prop.sale_price
                assign price_strikethrough = selected_prop.regular_price
            else 
                assign price = selected_prop.regular_price
                assign price_strikethrough = ''
            endif
        endif
    endif
%}    
    <div class="cell">
        <div class="wrap grid-y">
            <div class="img-wrap">
            {% if selected_prop.stock_level < 1 %}
                <div class="out-of-stock"></div>
            {% endif %}
            {% if selected_prop.is_on_sale == true %}
                <div class="sale-tag">SALE</div>
            {% endif %}
            {% if product.product_image.url %}
                {% assign image_url = product.product_image.url | replace: ' ', '%20' | replace: ';', '%3B' %}                               
                {%- capture img_cache_key -%} product_image-{{ product.id }}-{{ product.updated_at }} {%- endcapture -%}
                {% cache img_cache_key %}
                <img src="{{ image_url }}" alt="{{ product.product_name }}" loading="lazy">
                {% endcache %}
            {% else %}
                {% include 'modules/website/layout/placeholder_image', size: 'medium' %}
            {% endif %}
            </div>
            <div class="spacer medium"></div>
            <div class="container grid-y flex-grow-1">
                <div class="details">
                    <h6>{{ product.product_name }}</h6>
                    <div class="spacer x-small"></div>
                    {% assign category = all_categories | array_detect: uuid: product.category_uuids[0] %}
                    <p class="body-x-small">{{ category.category_name | default: 'Category' | capitalize }}</p>
                    <div class="spacer"></div>
                    <p class="product-current-price">{{ price | pricify }}
                        {% if product.is_on_sale == true or variant.is_on_sale == true %}
                        <span class="body-x-small strikethrough">{{ price_strikethrough }}</span>
                        {% endif %}
                    </p>
                    <div class="spacer"></div>
                    {% if purchase_date  %}
                    <p class="body-x-small">Purchase Date: {{purchase_date | date: '%d/%m/%Y'}}</p>
                    <div class="spacer"></div>
                    {% endif %}
                </div>
                <div class="buttons">
                    {% parse_json data %}
                    {
                        "id": "{{ selected_prop.id }}",
                        "slug": "{{ product.slug }}",
                        "product_uuid": "{{ product.uuid }}",
                        "product_sku": "{{ selected_prop.sku }}",
                        "variant_uuid": "{{ variant_uuid }}",
                        "product_name": "{{ product.product_name | replace: "'", "`"}}",
                        "price": "{{ price | default: 0 | advanced_format: '%.2f' }}",
                        "image": "{{ image_url }}"
                    }
                    {% endparse_json %}

                    <ins-button class="full {{class_add_to_cart_btn}}" label="Add to cart" data='{{ data }}' solid color="blue" icon="icon-shopping-cart"></ins-button>
                    <div class="spacer x-small"></div>
                    <a href="/products/{{ product.slug }}">
                        <ins-button class="full" label="View details" outlined icon="icon-eye"></ins-button>
                    </a>
                </div>
            </div>
        </div>
    </div>