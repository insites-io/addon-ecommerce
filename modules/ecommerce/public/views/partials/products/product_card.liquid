---
metadata: {
    partial_name: 'Ecommerce | Products | Product Card'
}
---
{%  liquid

    if ordered_item == true
        assign product = item.product
        if item.sku == product.sku
            assign selected_prop = product
        else
            for variant in product.variants
                if item.sku == variant.sku
                    assign selected_prop = variant
                    assign is_variant = true
                endif
            endfor
        endif
    elsif product.is_product_variant_enabled
        assign class_add_to_cart_btn = ''
        assign label_add_tocart_btn = 'Select Variant'
        assign selected_prop = product.variant
        assign product_variant_uuid = product.variant.uuid
    else
        assign class_add_to_cart_btn = 'add-to-cart-btn'
        assign label_add_tocart_btn = 'Add to Cart'
        assign selected_prop = product
        assign product_variant_uuid = null
    endif


    ## Pricing
    ## Use product details here even if the variant is enabled
    include 'modules/ecommerce/products/pricing', product: product
    assign price = context.exports.price
    assign price_strikethrough = context.exports.price_strikethrough
    assign is_tax_included = context.exports.is_tax_included

    ## If price is empty and the item is a variant, then use the variant pricing
    if price == '' or price == blank
        if product.is_product_variant_enabled
            if selected_prop.is_on_sale == true
                assign price = selected_prop.sale_price
                assign price_strikethrough = selected_prop.regular_price
            else
                assign price = selected_prop.regular_price
                assign price_strikethrough = ''
            endif
        endif
    endif

    ## ── Card enrichment (looked up from the page-level batch fetches in grid.liquid) ──
    ## Custom fields: tags + per-product low-stock override
    assign cf = cf_rows | where: 'product_uuid', product.uuid | first
    assign product_tags = cf.tags
    assign low_override = cf.low_stock_override

    ## Stock indicator state — purchasable stock vs the per-product low-stock override.
    ## selected_prop is the product (non-variant) or the active variant, matching the
    ## out-of-stock overlay; fall back to product-level stock if the variant is blank.
    assign stock_now = selected_prop.stock_level
    if stock_now == blank
        assign stock_now = product.stock_level
    endif
    assign stock_now = stock_now | default: 0 | plus: 0
    assign stock_state = 'in'
    if stock_now <= 0
        assign stock_state = 'out'
    elsif low_override == blank
        assign stock_state = 'in'
    else
        assign half_override = low_override | times: 1.0 | divided_by: 2.0
        if half_override > stock_now
            assign stock_state = 'very-low'
        elsif low_override >= stock_now
            assign stock_state = 'low'
        else
            assign stock_state = 'in'
        endif
    endif

    ## Rating — average + count of this product`s approved reviews
    assign my_reviews = review_rows | where: 'reviewed_product', product.uuid
    assign review_count = my_reviews | size
    assign rating_sum = 0
    for rv in my_reviews
        assign rating_sum = rating_sum | plus: rv.rating
    endfor
    assign avg_rating = 0
    if review_count > 0
        assign avg_rating = rating_sum | times: 1.0 | divided_by: review_count
    endif

    ## Sold — total units sold across completed orders
    assign sold_items = sold_rows | where: 'product_uuid', product.uuid
    assign sold_count = 0
    for si in sold_items
        assign sold_count = sold_count | plus: si.quantity
    endfor
%}
    <div class="cell">
        <div class="wrap grid-y">
            <div class="img-wrap">
            {% if selected_prop.stock_level < 1 or selected_prop.stock_level == blank %}
                <div class="out-of-stock"></div>
            {% endif %}
            {%- if product_tags and product_tags.size > 0 -%}
                <div class="product-tags">
                    {%- for tag in product_tags -%}
                        {% include 'modules/ecommerce/products/tag_chip', tag: tag %}
                    {%- endfor -%}
                </div>
            {%- endif -%}
            {% if product.product_image.url %}
                {% assign image_url = product.product_image.url | replace: ' ', '%20' | escape %}
                {%- capture img_cache_key -%} product_image-{{ product.id }}-{{ product.updated_at }} {%- endcapture -%}
                {% cache img_cache_key %}
                {% if fetchpriority == 'high' %}
                <img src="{{ image_url }}" alt="{{ product.product_name }}" fetchpriority="high" width="300" height="286">
                {% else %}
                <img src="{{ image_url }}" alt="{{ product.product_name }}" loading="lazy" width="300" height="286">
                {% endif %}
                {% endcache %}
            {% else %}
                {% include 'modules/website/layout/placeholder_image', size: 'medium' %}
            {% endif %}
            </div>
            <div class="spacer medium"></div>
            <div class="container grid-y flex-grow-1">
                <div class="details">
                    {%- if product.brand and product.brand != blank -%}
                        <p class="product-brand">{{ product.brand }}</p>
                        <div class="spacer x-small"></div>
                    {%- endif -%}
                    {% if heading_level == 'h2' %}
                        <h2 class="heading-6">{{ product.product_name }}</h2>
                    {% elsif heading_level == 'h3' %}
                        <h3 class="heading-6">{{ product.product_name }}</h3>
                    {% elsif heading_level == 'h4' %}
                        <h4 class="heading-6">{{ product.product_name }}</h4>
                    {% elsif heading_level == 'h5' %}
                        <h5 class="heading-6">{{ product.product_name }}</h5>
                    {% else %}
                        <h6>{{ product.product_name }}</h6>
                    {% endif %}
                    {%- if review_count > 0 or sold_count > 0 -%}
                        <div class="spacer x-small"></div>
                        <div class="product-meta">
                            {%- if review_count > 0 -%}
                                <span class="product-rating">
                                    {% include 'modules/ecommerce/reviews/star_rating', rating: avg_rating, size: 16 %}
                                    <span class="product-rating__count body-small bold">({{ review_count }})</span>
                                </span>
                            {%- endif -%}
                            {%- if sold_count > 0 -%}
                                <span class="product-sold body-small bold">{{ sold_count }} sold</span>
                            {%- endif -%}
                        </div>
                    {%- endif -%}
                    <div class="spacer"></div>
                    <p class="product-current-price">{{ price | pricify }}
                        {% if product.is_on_sale == true or variant.is_on_sale == true %}
                        <span class="body-x-small strikethrough">{{ price_strikethrough }}</span>
                        {% endif %}
                    </p>
                    <div class="spacer x-small"></div>
                    <p class="stock-indicator stock-indicator--{{ stock_state }} body-small">
                        {%- case stock_state -%}
                            {%- when 'out' -%}Out of stock
                            {%- when 'low' -%}Low stock ({{ stock_now }})
                            {%- when 'very-low' -%}Very low stock ({{ stock_now }})
                            {%- else -%}In stock ({{ stock_now }})
                        {%- endcase -%}
                    </p>
                    <div class="spacer"></div>
                    {% if purchase_date  %}
                    <p class="body-x-small">Purchase Date: {{purchase_date | date: '%d/%m/%Y'}}</p>
                    <div class="spacer"></div>
                    {% endif %}
                </div>
                <div class="buttons">
                    {% parse_json data_old %}
                    {
                        "id": "{{ selected_prop.id }}",
                        "slug": "{{ product.slug }}",
                        "product_name": "{{ product.product_name | replace: "'", "`"}}",
                        "image": "{{ image_url }}",
                        "product_sku": "{{ selected_prop.sku }}",
                        "product_uuid": "{{ product.uuid }}",
                        "product_variant_uuid": "{{ product_variant_uuid }}",
                        "price": {{ price | default: 0 | advanced_format: '%.2f' }},
                        "stock_level": {{ selected_prop.stock_level | default: 0 }},
                        "tax_amount": {{ product.tax_amount | default: 0 }},
                        "is_tax_included": {{ is_tax_included | default: false }},
                        "is_fixed_tax_amount": {{ product.is_fixed_tax_amount | default: false }}
                    }
                    {% endparse_json %}

                    {% parse_json data %}
                    {
                        "product_uuid": "{{ product.uuid }}",
                        "product_variant_uuid": "{{ product_variant_uuid }}"
                    }
                    {% endparse_json %}

                    <ins-button class="full {{class_add_to_cart_btn}}" label="{{ label_add_tocart_btn }}" data='{{ data }}' solid color="blue" icon="icon-shopping-cart"></ins-button>
                    <div class="spacer x-small"></div>
                    <a href="/products/{{ product.slug }}">
                        <ins-button class="full" label="View details" outlined icon="icon-eye"></ins-button>
                    </a>
                </div>
            </div>
        </div>
    </div>
