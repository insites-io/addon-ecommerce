{%   liquid 
     ## Use product details here even if variant is enabled
     assign price_strikethrough = ''
     if product.is_on_sale == true 
          assign price = product.sale_price
          if product.regular_price > 0
               assign price_strikethrough = product.regular_price | pricify: 'USD', no_cents_if_whole: false
          endif
          #Tax
          assign is_tax_included = product.is_sale_price_tax_included
     else 
          assign price = product.regular_price        
          #Tax
          assign is_tax_included = product.is_tax_included
     endif

     export price, price_strikethrough, is_tax_included
%}