---
slug: api/stripe/create-credit-card
format: json
method: post
searchable: false
metadata: {
  "status": "published",
  "open_graph:title": "Create Credit Card",
  "open_graph:description": "Create Credit Card",
  "meta_title": "Create Credit Card",
  "page_title": "Create Credit Card",
  "meta_description": "Create Credit Card",
  "canonical_url": "",
  "is_visible_to_search_engines": "false",
  "sitemap_priority": 0.0, ## primary order (DESC)
  "sitemap_order": 9999, ## secondary order (ASC)
  "sitemap_changefreq": "never"
}
---

{%- assign status = 200 -%}
{%- assign payload = context.params.payload | parse_json -%}
{%- assign customer_email = payload.email | strip -%}
{%- assign stripe_customer_id = blank -%}
{%- assign user_id = blank -%}

{%- liquid
    if context.current_user
        assign customer_name = context.current_user.first_name | append: " " | append: context.current_user.last_name 
    else
        ## guest user
        assign customer_name = context.session.billing_contact_first_name | append: " " | append: context.session.billing_contact_last_name 
    endif
-%}

{%- comment -%} Check the CRM contact to see if the user with this email has a Stripe ID {%- endcomment -%}
{%- if context.current_user -%}
    {%- graphql user_stripe = 'modules/client/customers/get_user_stripe_id', email: customer_email | dig: 'items','results' | first -%}
    {%- assign user_id = user_stripe.id -%}
    {%- assign user_uuid = user_stripe.external_id -%}
    {%- assign stripe_id = user_stripe | dig: 'profiles' | first | dig: 'stripe_id' -%}
{%- endif -%}


{%- if stripe_id and stripe_id != '' -%}

    {%- comment -%} User already has a stripe_id: Proceed in creating new Stripe card {%- endcomment -%}
    {%- parse_json data -%}
    {
        "contact_uuid": "{{ user_uuid }}",
        "payment_method_token":  "{{ stripe_id }}",
        "source": "{{ payload.stripe_credit_card }}"
    }
    {%- endparse_json -%}
    {%- include 'modules/ecommerce/stripe/credit_cards/create_credit_card', data: data -%}

{%- else -%}
    {%- comment -%} New customer: Create Stripe customer {%- endcomment -%}    
    {%- parse_json customer_data -%}
    {
        "email": "{{ customer_email }}",
        "name": "{{ customer_name }}",
        "description": ""
    }
    {%- endparse_json -%}
    {%- graphql create_stripe_customer = 'modules/ecommerce/system/trigger_api_call', name: "modules/ecommerce/create_customer",
        data: customer_data | dig: 'items' | dig: 'response' -%}    

    {%- assign stripe_customer_response = create_stripe_customer.body | parse_json  -%}
    {%- assign stripe_customer_id = stripe_customer_response.id -%}

    {%- comment -%} Save the Stripe ID to the CRM contact {%- endcomment -%}
    {%- if context.current_user -%}

        {%- parse_json crm_data -%}
        {
            "id": "{{ user_id }}", 
            "email": "{{ customer_email }}",
            "stripe_id": "{{ stripe_customer_id }}"
        }
        {%- endparse_json -%}    
        {%- graphql update_contact = 'modules/ecommerce/system/trigger_api_call', 
            name: 'modules/client/update_contact', 
            data: crm_data | dig: 'items','response','body' | parse_json -%}

        {%- log update_contact, type: 'new stripe customer, update_contact' -%}

    {%- else -%}

        {%- comment -%} Guest user: check if email already exist {%- endcomment -%}
        {%- graphql user_exist = "modules/ecommerce/user/get_user_by_email", email: customer_email | dig: "items" -%}

        {%- comment -%} Create new user account {%- endcomment -%}
        {%- if user_exist.total_entries == 0 -%}
            {%- assign password = 'now' | date: '%y%m%d' | uuid  -%}
            {%- parse_json new_user_data -%}
            {
                "email": "{{ customer_email }}",
                "first_name": "{{ context.session.billing_contact_first_name }}",
                "last_name": "{{ context.session.billing_contact_last_name }}",
                "password": "{{ password }}",
                "uuid": "{{ '' | uuid }}",
                "email": "{{ customer_email }}",
                "mobile_phone_number": "{{ context.session.billing_contact_phone_number }}",
                "mobile_phone_country_code": "{{ context.session.billing_contact_phone_country_code }}",
                "stripe_id": "{{ stripe_customer_id }}"
            }
            {%- endparse_json -%}
            {%- graphql new_user = 'modules/ecommerce/user/create_user', args: new_user_data -%}
            {%- assign user_uuid = new_user.user.user_uuid -%}

            {%- comment -%} Auto login user after creation of user account {%- endcomment -%}
            {%- if new_user.user.id -%}
                {%- graphql logged_user = 'modules/ecommerce/account/create_user_session', email: customer_email, password: password -%}               
                {%- assign is_new_user = true -%}
                {%- log '====TEST Auto login user' -%}
            {%- endif -%}
        {%- endif -%}

    {%- endif -%}

    {%- parse_json data -%}
    {
        "contact_uuid": "{{ user_uuid }}",
        "payment_method_token":  "{{ stripe_customer_id }}",
        "source": "{{ payload.stripe_credit_card }}"
    }
    {%- endparse_json -%}
    {%- include 'modules/ecommerce/stripe/credit_cards/create_credit_card', data: data -%}
{%- endif -%}

{
    "stripe_id": "{{context.exports.stripe_response.id}}",
    "is_new_user": {{ is_new_user | default: false }}
}
{%- response_status status -%}