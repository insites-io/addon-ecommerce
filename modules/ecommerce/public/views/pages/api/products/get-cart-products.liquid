---
slug: api/get-cart-products
format: json
method: get
searchable: false
---

{%- assign status = 400 -%}
{%- assign params = context.params -%}
{%- assign product_uuids = params.product_uuids | split: ',' -%}

{%- if product_uuids.size > 0 -%}
    {%- graphql products = 'modules/ecommerce/products/get_cart_products', 
        uuid: product_uuids, size: product_uuids.size | dig: 'items' -%}
{%- endif %}

{%- if products.results %}
    {%- assign status = 200 -%}
{%- endif %}


{{- products.results -}}
{%- response_status status -%}