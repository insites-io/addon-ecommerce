---
slug: api/add-to-cart
format: json
method: post
searchable: false
metadata: {
    "status": "published",
    "api_endpoint_name": "Add to cart"
}
---

{% comment %}
  The final computation of prices is done in compute_order_summary,
  so it is safe to use the payload here instead of fetching product details from the database.
  This avoids redundant database queries that could cause performance issues.
{% endcomment %}

{%- comment -%}
{%- liquid
    # use plus filter to make sure the value is a number
    assign params = context.params
    assign contact_uuid = params.contact_uuid
    assign type = params.type
    assign quantity = params.quantity | plus: 0
    assign product_uuid = params.product_uuid
    assign product_variant_uuid = params.product_variant_uuid
    assign product_sku = params.product_sku
    assign product_price = params.price | plus: 0 | default: 0
    assign product_name = params.product_name

    ## Tax    
    assign tax_amount =  params.tax_amount | plus: 0 | default: 0
    assign is_tax_included = params.is_tax_included
    assign is_fixed_tax_amount = params.is_fixed_tax_amount
    assign is_product_price_includes_tax = is_tax_included

    if is_fixed_tax_amount == true or is_fixed_tax_amount == 'true'
        assign tax_type = 'fixed'
        assign item_tax = tax_amount | times: quantity      
    else
        assign tax_type = 'percentage'
        assign item_tax = product_price | times: tax_amount | divided_by: 100 | times: quantity         
    endif

    
    # sub_total  = //should not exist in cart_item, need to confirm with insites   

    ## line_item_total
    if is_tax_included == true or is_tax_included == 'true'
        assign line_item_total = product_price | times: quantity
    else
        assign line_item_total = product_price | times: quantity | plus: item_tax      
    endif
    
-%}

{%- if contact_uuid != blank and contact_uuid != '' -%}

    Add cart item data 
    {%- parse_json add_cart_item_data -%}
    {          
        "uuid": "{{ '' | uuid }}",
        "quantity": {{ quantity | default: 1 }},
        "product_uuid": "{{ product_uuid }}",
        "product_variant_uuid": "{{ product_variant_uuid }}",
        "product_sku": "{{ product_sku }}", 
        "product_price": {{ product_price | advanced_format: '%.2f' | default: 0 }}, 
        "product_name": "{{ product_name }}",                  
        "tax_amount": {{ tax_amount | advanced_format: '%.2f' | default: 0 }},
        "item_tax": {{ item_tax | advanced_format: '%.2f'| default: 0 }},                  
        "product_price_includes_tax": {{ is_product_price_includes_tax | default: false }}, 
        "tax_type": "{{ tax_type }}",
        "line_item_total": {{ line_item_total | advanced_format: '%.2f' | default: 0 }},
        "sub_total": {{ sub_total | advanced_format: '%.2f' | default: 0 }}
    }
    {%- endparse_json -%}

   Check if the user already has a cart 
    {%- graphql cart = 'modules/ecommerce/carts/get_cart', 
        contact_uuid: params.contact_uuid | dig: 'items','results' | first -%}

    {%- if cart.uuid -%}
         This user already has a cart.             
       Check if the product is already added in the cart_item 
        {%- if product_variant_uuid != null and product_variant_uuid != '' -%}
            {%- assign product_exist = cart.cart_items | array_detect: product_variant_uuid: product_variant_uuid -%}
        {%- else -%}
            {%- assign product_exist = cart.cart_items | array_detect: product_uuid: product_uuid -%}
        {%- endif -%}

        {%- if product_exist.id -%}
            Update other fields not just the quantity, product data may have changed 
            {%- liquid
                if type == 'stepper'
                    assign new_quantity = quantity
                else
                    assign new_quantity = product_exist.quantity | plus: 1 
                endif
            -%}
            {%- parse_json cart_item_data -%}
            {
                "id": {{ product_exist.id }},
                "quantity": {{ new_quantity }},                
                "product_sku": "{{ product_sku }}", 
                "product_price": {{ product_price | advanced_format: '%.2f' | default: 0 }}, 
                "product_name": "{{ product_name }}",                  
                "tax_amount": {{ tax_amount | advanced_format: '%.2f' | default: 0 }},
                "item_tax": {{ item_tax | advanced_format: '%.2f'| default: 0 }},                  
                "product_price_includes_tax": {{ is_product_price_includes_tax | default: false }}, 
                "tax_type": "{{ tax_type }}",
                "line_item_total": {{ line_item_total | advanced_format: '%.2f' | default: 0 }},
                "sub_total": {{ sub_total | advanced_format: '%.2f' | default: 0 }}
            }
            {%- endparse_json -%}
            {%- graphql add_cart_item = 'modules/ecommerce/cart_items/update_cart_item', args: cart_item_data -%}
        {%- else -%}
             Add new item in the cart_item             
            {%- assign add_cart_item_data = add_cart_item_data | add_hash_key: 'cart_uuid', cart.uuid -%}
            {%- graphql add_cart_item = 'modules/ecommerce/cart_items/add_cart_item', args: add_cart_item_data -%}
        {%- endif -%}

    {%- else -%}

        The user does not have a cart yet
        Step 1: Add car
        {%- parse_json cart_data -%}
        {
            "uuid": "{{ '' | uuid }}",
            "contact_uuid": "{{ contact_uuid }}"
        }
        {%- endparse_json -%}
        {%- graphql add_cart = 'modules/ecommerce/carts/add_cart', args: cart_data | dig: 'items' -%}

         Step 2: Add cart_item
        {%- assign add_cart_item_data = add_cart_item_data | add_hash_key: 'cart_uuid', add_cart.uuid -%}
        {%- graphql add_cart_item = 'modules/ecommerce/cart_items/add_cart_item', args: add_cart_item_data -%}
        
    {%- endif -%}

    {{add_cart_item}}

{%- else -%}
    {
        "error": "contact_uuid is required"
    }
{%- endif -%}
{%- response_status 200 -%}
{% endcomment %}

{%- 
    liquid

    assign params = context.params
    assign contact_uuid = params.contact_uuid
    assign product_uuid = params.product_uuid
    assign product_variant_uuid = params.product_variant_uuid
    assign quantity = params.quantity | times: 1.0
    assign type = params.type | downcase

    assign return_data = '{}' | parse_json

    ## Check if the contact_uuid is available
    if contact_uuid != blank and contact_uuid != ''

        ## Build the data 
        assign add_cart_item_data = '{}' | parse_json
        assign add_cart_item_data = add_cart_item_data | add_hash_key: 'product_uuid', product_uuid

        # Get the details of the product
        function product_data = "ecommerce/controller/product/get", uuid: product_uuid
        assign add_cart_item_data = add_cart_item_data | add_hash_key: 'product_name', product_data.product_name

        ## Get current cart (if any)
        graphql cart = 'modules/ecommerce/carts/get_cart', contact_uuid: params.contact_uuid | dig: 'items','results' | first

        ## Check if the product already exist in the cart
        if cart.uuid
            if product_variant_uuid != blank
                assign product_exist = cart.cart_items | array_detect: product_variant_uuid: product_variant_uuid
            else
                assign product_exist = cart.cart_items | array_detect: product_uuid: product_uuid
            endif
            if product_exist.id
                ## Add previous quantity if not from a stepper
                unless type == 'stepper'
                    assign quantity = product_exist.quantity | plus: quantity
                endunless
            endif
        endif
        
        
        if product_variant_uuid != blank
            ## The product is variant so get all the info from the variant
            assign add_cart_item_data = add_cart_item_data | add_hash_key: 'product_variant_uuid', product_variant_uuid
            graphql cart = 'modules/ecommerce/products/get_product_variant', uuid: product_variant_uuid | dig: 'items','results' | first
            # function product_variant_data = "ecommerce/controller/product_variant/get", uuid: product_variant_uuid
            
            assign add_cart_item_data = add_cart_item_data | add_hash_key: 'product_sku', product_variant_data.product_sku

            if product_variant_data.is_on_sale == true or product_variant_data.is_on_sale == 'true'
                assign product_price = product_variant_data.sale_price
                assign product_price_includes_tax = product_variant_data.is_variant_sale_price_tax_included
            else
                assign product_price = product_variant_data.regular_price
                assign product_price_includes_tax = product_variant_data.is_tax_included
            endif

            if product_variant_data.is_fixed_tax_amount == true or product_variant_data.is_fixed_tax_amount == 'true'
                assign tax_type = 'fixed'
                assign item_tax = product_variant_data.tax_amount
                if product_price_includes_tax
                    assign line_item_total = product_price | times: quantity
                else
                    assign prod_w_tax = product_price | plus: item_tax
                    assign line_item_total = prod_w_tax | times: quantity
                endif
            else
                assign tax_type = 'percentage'
                if product_price_includes_tax
                    assign dec_tax = product_variant_data.tax_amount | divided_by: 100.00 | plus: 1.00
                    assign price_ex_tax = product_price | divided_by: dec_tax
                    assign item_tax = product_price | minus: price_ex_tax
                    assign line_item_total = product_price | times: quantity
                else
                    assign tax_val = product_variant_data.tax_amount | divided_by: 100.00
                    assign item_tax = product_price | times: tax_val
                    assign prod_w_tax = product_price | plus: item_tax
                    assign line_item_total = prod_w_tax | times: quantity
                endif
            endif
            assign tax_amount = item_tax | times: quantity

        else
            ## The product is NOT a variant so get all the info from the main product
            assign add_cart_item_data = add_cart_item_data | add_hash_key: 'product_sku', product_data.sku

            if product_data.is_on_sale == true or product_data.is_on_sale == 'true'
                assign product_price = product_data.sale_price
                assign product_price_includes_tax = product_data.is_sale_price_tax_included
            else
                assign product_price = product_data.regular_price
                assign product_price_includes_tax = product_data.is_tax_included
            endif

            if product_data.is_fixed_tax_amount == true or product_data.is_fixed_tax_amount == 'true'
                assign tax_type = 'fixed'
                assign item_tax = product_data.tax_amount
                if product_price_includes_tax
                    assign line_item_total = product_price | times: quantity
                else
                    assign prod_w_tax = product_price | plus: item_tax
                    assign line_item_total = prod_w_tax| times: quantity
                endif
            else
                assign tax_type = 'percentage'
                if product_price_includes_tax
                    assign dec_tax = product_data.tax_amount | divided_by: 100.00 | plus: 1.00
                    assign price_ex_tax = product_price | divided_by: dec_tax
                    assign item_tax = product_price | minus: price_ex_tax
                    assign line_item_total = product_price | times: quantity
                else
                    assign tax_val = product_data.tax_amount | divided_by: 100.00
                    assign item_tax = product_price | times: tax_val
                    assign prod_w_tax = product_price | plus: item_tax
                    assign line_item_total = prod_w_tax | times: quantity
                endif
            endif
            assign tax_amount = item_tax | times: quantity

        endif

        assign add_cart_item_data = add_cart_item_data | add_hash_key: 'product_price', product_price 
        assign add_cart_item_data = add_cart_item_data | add_hash_key: 'tax_type', tax_type   
        assign add_cart_item_data = add_cart_item_data | add_hash_key: 'product_price_includes_tax', product_price_includes_tax 
        assign add_cart_item_data = add_cart_item_data | add_hash_key: 'item_tax', item_tax
        assign add_cart_item_data = add_cart_item_data | add_hash_key: 'tax_amount', tax_amount
        assign add_cart_item_data = add_cart_item_data | add_hash_key: 'line_item_total', line_item_total
        assign add_cart_item_data = add_cart_item_data | add_hash_key: 'sub_total', line_item_total

        ## Get the cart information if possible
       
        if cart.uuid
            ## User already has cart

            if product_exist.id
                ## Product exist in cart
                assign cart_item_id = product_exist.id | append: ""
                assign add_cart_item_data = add_cart_item_data | add_hash_key: 'id', cart_item_id
                assign int_qty = quantity | round: 0
                assign add_cart_item_data = add_cart_item_data | add_hash_key: 'quantity', int_qty
                graphql add_cart_item = 'modules/ecommerce/cart_items/update_cart_item', args: add_cart_item_data
            else
                ## Product does not exist in cart
                assign item_uuid = '' | uuid
                assign int_qty = quantity | round: 0
                assign add_cart_item_data = add_cart_item_data | add_hash_key: 'quantity', int_qty
                assign add_cart_item_data = add_cart_item_data | add_hash_key: 'uuid', item_uuid
                assign add_cart_item_data = add_cart_item_data | add_hash_key: 'cart_uuid', cart.uuid
                graphql add_cart_item = 'modules/ecommerce/cart_items/add_cart_item', args: add_cart_item_data
            endif

        else
            
            ## User has no cart yet add cart 
            assign cart_uuid = '' | uuid
            assign cart_data = '{}' | parse_json
            assign cart_data = cart_data | add_hash_key: 'uuid', cart_uuid
            assign cart_data = cart_data | add_hash_key: 'contact_uuid', contact_uuid
            
            graphql add_cart = 'modules/ecommerce/carts/add_cart', args: cart_data | dig: 'items'
            
            ## Add cart_item 
            assign add_cart_item_data = add_cart_item_data | add_hash_key: 'cart_uuid', add_cart.uuid
            assign int_qty = quantity | round: 0
            assign add_cart_item_data = add_cart_item_data | add_hash_key: 'quantity', int_qty
            assign item_uuid = '' | uuid
            assign add_cart_item_data = add_cart_item_data | add_hash_key: 'uuid', item_uuid
            graphql add_cart_item = 'modules/ecommerce/cart_items/add_cart_item', args: add_cart_item_data
        
        endif

        ## Send additional detail regarding main product
        assign prod_details = '{}' | parse_json
        assign prod_details = prod_details | add_hash_key: 'product_slug', product_data.product_slug
        assign prod_details = prod_details | add_hash_key: 'product_image', product_data.product_image
        assign prod_details = prod_details | add_hash_key: 'stock_level', product_data.stock_level
        assign prod_details = prod_details | add_hash_key: 'product_uuid', product_uuid
        assign prod_details = prod_details | add_hash_key: 'product_variant_uuid', product_variant_uuid

        assign add_cart_item = add_cart_item | add_hash_key: 'prod_details', prod_details

        assign return_data = add_cart_item

    else
        assign return_data = return_data | add_hash_key: "error", "contact_uuid is required"
    endif

    response_status 200
-%}

{{ return_data }}