---
slug: api/add-to-cart
format: json
method: post
searchable: false
metadata: {
    "status": "published",
    "api_endpoint_name": "Add to cart"
}
---

{%- 
    liquid

    assign params = context.params
    ## Resolve the cart owner server-side — never trust a client-supplied
    ## contact_uuid (it would let a caller read or modify carts belonging to
    ## others). A member is identified by current_user.external_id, a guest by
    ## their session guest_temp_uuid (same resolution used across the storefront).
    function contact_uuid = 'modules/ecommerce/user/get_user_uuid'
    assign product_uuid = params.product_uuid
    assign product_variant_uuid = params.product_variant_uuid
    assign quantity = params.quantity | times: 1.0
    assign type = params.type | downcase

    assign return_data = '{}' | parse_json
    assign prod_details = '{}' | parse_json

    ## Check if the contact_uuid is available
    if contact_uuid != blank and contact_uuid != ''

        ## Build the data
        assign add_cart_item_data = '{}' | parse_json
        assign add_cart_item_data = add_cart_item_data | add_hash_key: 'product_uuid', product_uuid

        # Get the details of the product
        function product_data = "ecommerce/controller/product/get", uuid: product_uuid

        ## Get current cart (if any)
        ## Keep using graphql instead of function/controller to leverage the cart_items relationship and avoid multiple calls
        graphql cart = 'modules/ecommerce/carts/get_cart', contact_uuid: contact_uuid | dig: 'items','results' | first       

        ## Check if the product already exist in the cart
        if cart.uuid
            if product_variant_uuid != blank
                assign product_exist = cart.cart_items | array_detect: product_variant_uuid: product_variant_uuid
            else
                assign product_exist = cart.cart_items | array_detect: product_uuid: product_uuid
            endif
            if product_exist.id
                ## Add previous quantity if not from a stepper
                unless type == 'stepper'
                    assign quantity = product_exist.quantity | plus: quantity
                endunless
            endif
        endif

        ## Resolve product SKU and price from product/variant for client-side response
        if product_variant_uuid != blank
            ## The product is a variant
            assign add_cart_item_data = add_cart_item_data | add_hash_key: 'product_variant_uuid', product_variant_uuid
            graphql product_variant_data = 'modules/ecommerce/products/get_product_variant', uuid: product_variant_uuid | dig: 'items','results' | first

            assign product_sku = product_variant_data.product_sku
            ## Net (ex-tax) price for the client-side cart drawer — effective_price
            ## (v5.11.3). Response-only: never persisted to the cart_item record.
            assign product_price = product_variant_data.effective_price
            if product_price == blank or product_price == null
                if product_variant_data.is_on_sale == true or product_variant_data.is_on_sale == 'true'
                    assign product_price = product_variant_data.sale_price
                else
                    assign product_price = product_variant_data.regular_price
                endif
            endif

            assign prod_details = prod_details | add_hash_key: 'product_options', product_variant_data.product_options
        else
            ## The product is NOT a variant
            assign product_sku = product_data.sku
            ## Net (ex-tax) price for the client-side cart drawer — effective_price
            ## (v5.11.3). Response-only: never persisted to the cart_item record.
            assign product_price = product_data.effective_price
            if product_price == blank or product_price == null
                if product_data.is_on_sale == true or product_data.is_on_sale == 'true'
                    assign product_price = product_data.sale_price
                else
                    assign product_price = product_data.regular_price
                endif
            endif
        endif

        ## Get the cart information if possible
       
        if cart.uuid
            ## User already has cart

            if product_exist.id
                ## Product exist in cart                
                assign int_qty = quantity | round: 0
                assign add_cart_item_data = add_cart_item_data | add_hash_key: 'quantity', int_qty
                function add_cart_item = "ecommerce/controller/cart_items/update", uuid: product_exist.uuid, params: add_cart_item_data
            else
                ## Product does not exist in cart
                assign int_qty = quantity | round: 0
                assign add_cart_item_data = add_cart_item_data | add_hash_key: 'quantity', int_qty
                assign add_cart_item_data = add_cart_item_data | add_hash_key: 'cart_uuid', cart.uuid
                function add_cart_item = "ecommerce/controller/cart_items/create", params: add_cart_item_data
            endif

        else
            
            ## User has no cart yet — create it.
            ## NOTE: create via the add_cart GraphQL mutation directly, NOT the
            ## cart/create controller. The controller validates contact_uuid against a
            ## real CRM contact, which a guest does not have (their id is a session
            ## guest-* uuid), so it fails to create the cart and the cart_item then
            ## errors with missing_cart_uuid. The mutation stores contact_uuid as-is
            ## and uses the uuid we pass, so we know the cart_uuid up front.
            assign new_cart_uuid = '' | uuid
            assign cart_data = '{}' | parse_json
            assign cart_data = cart_data | add_hash_key: 'uuid', new_cart_uuid
            assign cart_data = cart_data | add_hash_key: 'contact_uuid', contact_uuid
            graphql add_cart = 'modules/ecommerce/carts/add_cart', args: cart_data

            ## Add cart_item
            assign add_cart_item_data = add_cart_item_data | add_hash_key: 'cart_uuid', new_cart_uuid
            assign int_qty = quantity | round: 0
            assign add_cart_item_data = add_cart_item_data | add_hash_key: 'quantity', int_qty
            function add_cart_item = "ecommerce/controller/cart_items/create", params: add_cart_item_data 
        
        endif

        ## Augment response with product details for client-side rendering
        assign add_cart_item = add_cart_item | add_hash_key: 'product_name', product_data.product_name
        assign add_cart_item = add_cart_item | add_hash_key: 'product_sku', product_sku
        assign add_cart_item = add_cart_item | add_hash_key: 'product_price', product_price

        ## Send additional detail regarding main product

        assign prod_details = prod_details | add_hash_key: 'product_slug', product_data.product_slug
        assign prod_details = prod_details | add_hash_key: 'product_image', product_data.product_image
        assign prod_details = prod_details | add_hash_key: 'stock_level', product_data.stock_level
        assign prod_details = prod_details | add_hash_key: 'product_uuid', product_uuid
        assign prod_details = prod_details | add_hash_key: 'product_variant_uuid', product_variant_uuid

        assign return_data = return_data | add_hash_key: 'items', add_cart_item
        assign return_data = return_data | add_hash_key: 'prod_details', prod_details

    else
        assign return_data = return_data | add_hash_key: "error", "contact_uuid is required"
    endif

    response_status 200
-%}

{{ return_data }}