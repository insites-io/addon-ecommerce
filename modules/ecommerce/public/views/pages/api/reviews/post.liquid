---
slug: api/reviews/create
format: json
method: post
searchable: false
metadata: {
    "status": "published",
    "api_endpoint_name": "Create product review"
}
---
{%- liquid
    assign params = context.params
    assign status = 400
    assign errors = '[]' | parse_json
    assign response = '{}' | parse_json

    assign reviewed_product = params.reviewed_product | strip
    assign rating = params.rating | plus: 0
    assign review_content = params.review_content | strip

    ## Reviewer identity is derived server-side for signed-in users so the
    ## posted name/email cannot be spoofed; guests submit their own details.
    assign user = context.current_user
    if user.id
        assign is_guest = false
        assign reviewer_first_name = user.first_name
        assign reviewer_last_name = user.last_name
        assign reviewer_email = user.email
    else
        assign is_guest = true
        assign reviewer_first_name = params.reviewer_first_name | strip
        assign reviewer_last_name = params.reviewer_last_name | strip
        assign reviewer_email = params.reviewer_email | strip
    endif

    ## ----- Server-side validation -----
    if reviewed_product == blank
        assign errors = errors | add_to_array: 'A product reference is required.'
    endif
    if rating < 1 or rating > 5
        assign errors = errors | add_to_array: 'Rating must be between 1 and 5.'
    endif
    if review_content == blank
        assign errors = errors | add_to_array: 'Review content is required.'
    endif
    if reviewer_first_name == blank or reviewer_last_name == blank
        assign errors = errors | add_to_array: 'Reviewer name is required.'
    endif
    if reviewer_email == blank
        assign errors = errors | add_to_array: 'Reviewer email is required.'
    endif
-%}

{%- if errors.size > 0 -%}
    {%- assign response = response | add_hash_key: 'success', false -%}
    {%- assign response = response | add_hash_key: 'errors', errors -%}
{%- else -%}
    {%- assign review_uuid = '' | uuid -%}
    {%- graphql create = 'modules/ecommerce/reviews/create_review',
        uuid: review_uuid,
        reviewed_product: reviewed_product,
        rating: rating,
        review_content: review_content,
        reviewer_first_name: reviewer_first_name,
        reviewer_last_name: reviewer_last_name,
        reviewer_email: reviewer_email,
        is_guest: is_guest
    -%}
    {%- assign created = create.items -%}
    {%- if created.uuid -%}
        {%- assign status = 200 -%}
        {%- assign response = response | add_hash_key: 'success', true -%}
        {%- assign response = response | add_hash_key: 'uuid', created.uuid -%}
        {%- assign response = response | add_hash_key: 'status', created.status -%}
    {%- else -%}
        {%- assign errs = '[]' | parse_json | add_to_array: 'Could not save your review. Please try again.' -%}
        {%- assign response = response | add_hash_key: 'success', false -%}
        {%- assign response = response | add_hash_key: 'errors', errs -%}
    {%- endif -%}
{%- endif -%}

{{ response }}
{%- response_status status -%}
