---
name: checkout_user_create
resource: User
resource_owner: anyone
redirect_to: checkout/shipping
flash_alert: Sorry-AddUser
flash_notice: Success-AddUser
fields:
  email:
    validation: 
      presence:
        message: Please use a valid email address
      email: 
        message: Please use a valid email address
  first_name:
    validation: 
      presence: 
        message: First name is required
  last_name:
    validation: 
      presence: 
        message: Last name is required
  company_name:
    property_options:
      virtual: true
  profiles:
    modules/insites_core/crm_contact:
      properties:
        uuid:
        mobile_phone_number:
        mobile_phone_country_code:  

callback_actions: |-     

  {% comment %} Create CRM Company {% endcomment %}
  {%- parse_json crm_company_data -%}
  {
    "properties": {
      "company_name": "{{ form.company_name }}"
    }
  }
  {%- endparse_json -%}
  {%- graphql crm_company = 'modules/website/trigger_api_call', 
        name: 'modules/portal/add_company', 
        data: crm_company_data | dig: 'items','response','body' | parse_json -%}
  {% log crm_company, type: "crm_company" %}


  {% comment %} Update CRM Contact {% endcomment %}
  {%- parse_json crm_contact_data -%}
  {
      "id": {{ form.id }},
      "email": "{{ form.email }}",
      "company_uuid": "{{ crm_company.items.uuid }}",
      "is_archived" : false
  }
  {%- endparse_json -%}
  {%- graphql crm_contact = 'modules/website/trigger_api_call', 
        name: 'modules/portal/update_contact', 
        data: crm_contact_data | dig: 'items','response','body' | parse_json -%}
  {% log crm_contact, type: "crm_contact" %}
  
  # Get newly created user uuid or external_id
  {%- graphql user = "modules/ecommerce/account/check_user_email_signup", email: form.email
      | dig: 'items','results' | first -%}

  {%- parse_json guest_user -%}
  {
      "id": "{{ user.id }}",
      "external_id": "{{ user.external_id }}",
      "email": "{{ form.email }}",
      "first_name": "{{ form.first_name }}",
      "last_name" : "{{ form.last_name }}"
  }
  {%- endparse_json -%}
  {%- session guest_user = guest_user -%}    

  {%- session crm_company_name = form.company_name | default: "" -%}  
  {%- session crm_contact_mobile_number = form.profiles['modules/insites_core/crm_contact'].properties.mobile_phone_number -%}
  {%- session crm_contact_mobile_country_code = form.profiles['modules/insites_core/crm_contact'].properties.mobile_phone_country_code -%}

  {%- session latest_step = 2 -%}    
---

{% include 'modules/ecommerce/checkout/checkout_contact_form', guest: true %}