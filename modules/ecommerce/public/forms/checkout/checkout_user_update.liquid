---
name: checkout_user_update
resource: User
resource_owner: anyone
redirect_to: checkout/shipping
flash_alert: Sorry-AddUser
flash_notice: Success-AddUser
fields:
  email:
    validation: 
      presence:
        message: Please use a valid email address
      email: 
        message: Please use a valid email address
  first_name:
    validation: 
      presence: 
        message: First name is required
  last_name:
    validation: 
      presence: 
        message: Last name is required
  
  company_name:
    property_options:
      virtual: true

  profiles:
    modules/insites_core/crm_contact:
      properties:
        mobile_phone_number:
        mobile_phone_country_code:

callback_actions: |-   
  ## api/save-checkout-session is called in checkout.js to save the user data to the session
---

{%- form 
  html-id: "checkout-account-detail" 
  html-novalidate: true 
  html-enctype="multipart/form-data" 
  html-onsubmit:"return Checkout.events.contactSubmit(event);" -%}

  {% include 'modules/ecommerce/checkout/checkout_contact_form' %}

{%- endform -%}