---
name: checkout_user_update
resource: User
resource_owner: anyone
redirect_to: checkout/shipping
flash_alert: Sorry-AddUser
flash_notice: Success-AddUser
fields:
  email:
    validation: 
      presence:
        message: Please use a valid email address
      email: 
        message: Please use a valid email address
  first_name:
    validation: 
      presence: 
        message: First name is required
  last_name:
    validation: 
      presence: 
        message: Last name is required
  
  company_name:
    property_options:
      virtual: true

  profiles:
    modules/insites_core/crm_contact:
      properties:
        mobile_phone_number:
        mobile_phone_country_code:

callback_actions: |- 
  {%- session crm_company_name = form.company_name | default: "" -%}  
  {%- session crm_contact_mobile_number = form.profiles['modules/insites_core/crm_contact'].properties.mobile_phone_number | default: "" -%}
  {%- session crm_contact_mobile_country_code = form.profiles['modules/insites_core/crm_contact'].properties.mobile_phone_country_code | default: "" -%}

  {% unless context.current_user %}
    {%- parse_json guest_user -%}
    {
        "id": "{{ context.session.guest_user.id }}",
        "external_id": "{{ context.session.guest_user.external_id }}",
        "email": "{{ form.email }}",
        "first_name": "{{ form.first_name }}",
        "last_name" : "{{ form.last_name }}"
    }
    {%- endparse_json -%}
    {%- session guest_user = guest_user -%}
  {% endunless %}

  {%- session latest_step = 2 -%}
---

{% include 'modules/ecommerce/checkout/checkout_contact_form' %}