            "uuid": "{{ '' | uuid }}",
            "seller_id": "{{ context.session.cart_seller_id }}",
            "seller_email": "{{ context.session.seller_email }}",
            "seller_name": "{{ context.session.seller_name }}"            
        }
    }
callback_actions: >
    {%- comment -%}
    These actions are made intentionally on `callback_actions` and not on `async_callback_action` bec.
    confirmation page needs to be able to see the 'payment details' & cart summary. 
     
    START: Checkout callback process
        - API call to Stripe (Payment)
        - Create / Update models
        - Trigger Email & API callback via GraphQL    
    {%- endcomment -%}
    
    {%- assign user_id = context.current_user.id | default: "" -%}
    {% export user_id %}
    {%- include 'modules/ecommerce/checkout/callback_init', 
        form: form
        context: context -%}
    {%- comment -%}END: Checkout callback process{%- endcomment -%}

    {%- session latest_step = 5 -%}

async_callback_actions:
  delay: 0
  priority: low
  max_attempts: 2
  content: |-

    {% assign props = form.properties %}

    {% comment %} Get current_user uuid {% endcomment %}
    {% graphql current_user_uuid = 'modules/ecommerce/account/get_current_user' | dig: 'current_user','uuid' %}

    {% comment %} Pipeline stage: no_quote_requested or quote_requested {% endcomment %}
    {%  liquid
        assign stage_uuid = context.constants.pipeline_stage_no_quote_requested
        if props.freight_method == 'Delivery'
            assign stage_uuid = context.constants.pipeline_stage_quote_requested
        endif
    %}

    {% comment %} Create Opportunity {% endcomment %}
    {% parse_json data %}
    {
        "uuid": "{{ '' | uuid }}",
        "name": "Order #{{ form.id }}",
        "owner_uuid": "{{ current_user_uuid }}",
        "target_conversion_date": "{{ props.preferred_delivery_date | date: '%Y-%m-%d' }}",
        "pipeline_uuid": "{{ context.constants.pipeline_quote }}",
        "stage_uuid": "{{ stage_uuid }}",
        "value": "{{ props.total_amount }}",
        "status": "open",
        "database_item_id": "{{ form.id }}"
    }
    {% endparse_json %}
    {% graphql create_opportunity = 'modules/ecommerce/pipeline/create_opportunity', args: data %} 


    {% comment %} Send Quote Request to all Freight Provider within the area {% endcomment %}
    {% if props.freight_method == 'Delivery' %}
        
        {% assign seller_shipping_locations = props.seller_shipping_locations | split: ',' %}
        {% graphql freight_providers = 'modules/ecommerce/user/get_freight_providers' | dig: 'items','results' %}

        {% comment %} Assign opportunity on freight providers within the area {% endcomment %}
        {% assign data = '' | split: ','  %}
        {%- for item in freight_providers -%} 
            {%- liquid
                #check seller & freight provider shipping locations 
                assign seller_freight_area = item.freight_provider.shipping_locations | array_intersect: seller_shipping_locations

                #check buyer & freight provider shipping locations 
                assign buyer_freight_area = item.freight_provider.shipping_locations | array_any: props.shipping_state

                if item.freight_provider.shipping_locations.size == 0
                    continue

                #seller & freight
                elsif item.crm_contact[0].company.address.country != props.seller_shipping_country
                    continue 
                elsif seller_freight_area.size == 0
                    continue

                #buyer & freight
                elsif item.crm_contact[0].company.address.country != props.shipping_country
                    continue
                elsif buyer_freight_area == false
                    continue
                endif
            -%} 
            {% parse_json temp_data %}
            {
                "table": "modules/insites_pipeline/opportunity_related_contact", 
                "properties": { 
                    "uuid": "{{ '' | uuid }}", 
                    "contact_uuid": "{{ item.uuid }}",  
                    "relationship": "Freight provider candidate", 
                    "opportunity_uuid": "{{ create_opportunity.items.properties.uuid }}" 
                    }
            }
            {% endparse_json %}
            {% assign data = data | array_add: temp_data  %}
        {% endfor %}
        {% graphql opportunity_related_contact = 'modules/ecommerce/system/create_multiple_records_at_once', data: data %} 
    {% endif %}
---

{% graphql shipping_locations = 'modules/ecommerce/store/get_shipping_locations_by_cart', 
        administrator_uuid: context.session.user_uuid 
        | dig: 'items','results' | first %}

{% assign seller_shipping_country = shipping_locations.product.seller.related_user.crm_contact[0].address.country %}
{% assign seller_shipping_locations = shipping_locations.product.seller.related_user.seller.shipping_locations | join: ',' %}

{% form 
    html-id: "checkout-form"
    html-onsubmit:"return Checkout.events.paymentFormSubmit(event);"
    html-novalidate: true %}

    <input type="hidden" id="hidden-acount-email" value="{{context.session.billing_contact_email | default: ''}}" >
    <input type="hidden" name="{{ form.fields.properties.seller_shipping_country.name }}" value="{{seller_shipping_country}}" >
    <input type="hidden" name="{{ form.fields.properties.seller_shipping_locations.name }}" value="{{seller_shipping_locations}}" >
   

    <!-- Payment Details -->

    <div id="payment-details" class="aa">
        <h2 class="heading-1">Payment Method</h2>
        <div class="spacer xxx-large"></div>

        <div class="grid-x grid-padding-x">
            <div class="large-6 medium-6 small-12 cell">
                <h2 class="heading-2">Credit Card</h2>
            </div>
            <div class="large-6 medium-6 small-12 cell text-right">
                <div class="spacer x-small"></div>
                <ins-button type="button" id="add-card-btn" size="small" icon="icon-plus" label="Add Card">
                </ins-button>
            </div>
        </div>

        <div class="validate-credit-card">
            {% comment %} Credit Cards {% endcomment %}
            <div id="credit-card-fields" required class="card-fields">
                <div class="spacer x-large"></div>
                <p class="error-message hide">Credit Card is required.</p>
                <div id="card-options-list" class="grid-x grid-padding-x">
                    {%- if context.current_user.id -%}
                    {%- graphql cards = "modules/ecommerce/credit_cards/get_credit_card", 
                        user_id: context.current_user.id
                        size: 50 | dig: 'items' -%}
                    {%- for card in cards.results -%}
                        {%  liquid
                            assign is_card_active = ''
                            if forloop.first
                                assign selected_card = card.payment_method_token
                                assign is_card_active = 'active'
                            endif
                        %}
                        <div class="large-6 medium-6 small-12 cell card-options">
                            <ins-credit-card {{ is_card_active }} data-id="{{ card.id }}" brand="{{ card.card_brand }}"
                                last-four="{{ card.card_last_four_digits }}" expiry-month="{{ card.card_expiry_month }}"
                                expiry-year="{{ card.card_expiry_year }}" full-year
                                value="{{ card.payment_method_token }}">
                            </ins-credit-card>                        
                            <div class="spacer small"></div>
                        </div>
                    {%- endfor -%}
                    {%- endif -%}
                </div>
                <ins-input required validate
                    style="height:0px; display: block; overflow: hidden;"
                    field="hidden"
                    id="stripe-card"
                    name="{{ form.fields.properties.stripe_credit_card.name }}"
                    value="{{ selected_card }}"></ins-input>
            </div>

            <ins-card steady id="no-card" class="empty-state text-center {% if cards.total_entries > 0 %}hide{% endif %}">
                No Cards Added
            </ins-card>
        </div>
        {% comment %}END: Credit Cards {% endcomment %}

        <div class="spacer xxx-large"></div>

        {%- comment -%}Check if there's items to pay for{%- endcomment -%}
        {%- include 'modules/ecommerce/checkout/compute_order_summary' -%}
        <div class="grid-x grid-padding-x">
            <div class="large-12 medium-12 small-12 cell text-right">
                <div class="spacer small"></div>                

                {%- include 'modules/marketplace_stripe/get_stripe_settings' -%}
                {%- assign stripe_account_id = context.exports.stripe.data.account_id -%}
                
                {%- if stripe_account_id == '' or stripe_account_id == null -%}
                    <ins-button disabled color="negative"
                        label="Payment settings not configured, please contact website administrator.">
                    </ins-button>
                {%- else -%}
                    {%- if context.exports.order.total_amount > 0 -%}
                        <ins-button solid type="submit" id="checkout-submit-btn" class="w-100" label="Purchase Order">
                        </ins-button>
                    {%- else -%}
                        <ins-button disabled color="negative" label="No items to pay">
                        </ins-button>
                    {%- endif -%}
                {%- endif -%}
            </div>
        </div>
    </div>
    <!-- END Payment Details -->
    
{% endform %}

<!-- Stripe Element -->
{%- include 'modules/ecommerce/forms/stripe_element',
    cc_field_id: "checkout-credit-card"
    email_field_id: "hidden-acount-email" -%}
<!-- END Stripe Element -->