---
name: checkout_payment
resource: modules/insites_ecommerce/order
resource_owner: anyone
redirect_to: > 
    {% log form.properties.uuid, type: "==== Redirect To: confirmation?order_uuid= " %}
    {%- if context.exports.payment_response.status == "succeeded" or context.exports.payment_response.status == "active" -%}
    confirmation?order_uuid={{ form.properties.uuid }}
    {%- else -%}
        {%- if context.exports.payment_response.error.code == "card_declined" -%}
        checkout/payment?status=payment-error&type={{ context.exports.payment_response.error.decline_code | default: "" }}
        {%- else -%}
        checkout/payment?status=payment-error&type={{ context.exports.payment_response.error.code | default: "" }}
        {%- endif -%}    
    {%- endif -%}
fields:
    properties:
        ## Shipping Details
        shipping_company_name:
        shipping_contact_first_name:
            validation:
                presence:  
                    message: First name is required
        shipping_contact_last_name:
            validation:
                presence:  
                    message: Last name is required 
        shipping_contact_email:
            validation:
                email: 
                    message: Please use a valid email address
                presence:  
                    message: Please use a valid email address
        shipping_contact_phone_number:
        shipping_address_id:
            property_options:
                virtual: true
        shipping_address_1:
            validation:
                presence:  
                    message: Address is required 
        shipping_address_2:
        shipping_address_3:
        shipping_city:
            validation:
                presence:  
                    message: City is required 
        shipping_state:
            validation:
                presence:  
                    message: State is required 
        shipping_postcode:
            validation:
                presence:  
                    message: Postcode is required 
        shipping_country:
            validation:
                presence:  
                    message: Country is required 
        additional_shipping_cost:
            property_options:
                virtual: true
        shipping_instructions:
        freight_method:
            validation:
                presence: true        
        preferred_pick_up_date:
            property_options:
                virtual: true
        preferred_delivery_date:
            property_options:
                virtual: true
        
        ## Payment Details
        billing_company_name:
        billing_contact_first_name:
            validation:
                presence:  
                    message: First name is required 
        billing_contact_last_name:
            validation:
                presence:  
                    message: Last name is required 
        billing_contact_email:
            validation:
                email: 
                    message: Please use a valid email address
                presence:  
                    message: Please use a valid email address
        billing_contact_phone_number:
        billing_address_id:
            property_options:
                virtual: true
        billing_address_1:
            validation:
                presence:  
                    message: Address is required 
        billing_address_2:
        billing_address_3:
        billing_city:
            validation:
                presence:  
                    message: City name is required 
        billing_state:  
            validation:
                presence:
                    message: State is required 
        billing_postcode:
            validation:
                presence:  
                    message: Postcode is required 
        billing_country:
            validation:
                presence:  
                    message: Country is required 
        
        ## Payment Gateway
        gateway_id: 
            property_options:
                virtual: true
        stripe_credit_card:
            property_options:
                virtual: true
        statement_descriptor:
            property_options:
                virtual: true

        ## Transaction Details
        order_reference:
            validation:
                presence: true
        order_contact_uuid:
            validation:
                presence: true
        order_contact_first_name:
        order_contact_last_name:                
        order_status: ## String = "Paid" ??
        order_payment_status: ## String = "Paid" ??
        order_shipping_status: ## String = "Processing" 
        date_time: ## String! = date-time order success
        notes: ## stripe descrition
        currency: ## String! = AUD (System settings)
        subtotal_amount: ## Float!
        total_tax_amount: ## Float!
        total_shipping_amount: ## Float!
        total_amount: ## Float!
        uuid:
            validation:
                presence:  
                    message: UUID is required 

        #Custom Fields
        seller_id:
            property_options:
                virtual: true

        seller_email:
            property_options:
                virtual: true
        seller_name:
            property_options:
                virtual: true                
        seller_shipping_country:
            property_options:
                virtual: true 
        seller_shipping_locations:
            property_options:
                virtual: true                
default_payload: >
