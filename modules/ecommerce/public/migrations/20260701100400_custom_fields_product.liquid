{% comment %} Create Product Custom Fields: tags, low_stock_override {% endcomment %}
{% parse_json product_properties %}
[
    {
        "attribute_type": "array",
        "name": "tags",
        "metadata": {
            "label": "tags",
            "weight": 0,
            "options": [
                { "value": "Bestseller", "content": "Bestseller" },
                { "value": "20% Sale", "content": "20% Sale" },
                { "value": "Sale", "content": "Sale" },
                { "value": "New Arrival", "content": "New Arrival" },
                { "value": "Limited", "content": "Limited" },
                { "value": "Staff Pick", "content": "Staff Pick" }
            ],
            "ui_element": "card_select_multiple"
        }
    },
    {
        "attribute_type": "integer",
        "name": "low_stock_override",
        "metadata": {
            "label": "Low stock override",
            "weight": 1,
            "ui_element": "number"
        }
    }
]
{% endparse_json %}

{% graphql product_result, properties: product_properties %}
mutation save_custom_fields($properties: [NestedPropertyInputType]!) {
  items: admin_table_update(
    physical_file_path: "modules/ins_ecommerce/public/schema/product_custom_field.yml"
    table: { properties: $properties }
  ) {
    id
    name
    parameterized_name
    physical_file_path
    metadata
    properties {
      id
      name
      attribute_type
      belongs_to
      metadata
      options
      default_value
      target_type
      target_id
    }
  }
}

{% endgraphql %}
{% log product_result, type: "SEED DATA: product_custom_field tags, low_stock_override" %}


{% comment %} Add items to product_custom_field — guarded: only seed when the table has no records yet {% endcomment %}
{%- graphql existing_pcf -%}
  query {
    items: records(
      per_page: 1
      filter: {
        table: { value: "modules/ins_ecommerce/product_custom_field" }
        deleted_at: { exists: false }
      }
    ) {
      total_entries
    }
  }
{%- endgraphql -%}
{%- assign existing_pcf_count = existing_pcf.items.total_entries | default: 0 -%}
