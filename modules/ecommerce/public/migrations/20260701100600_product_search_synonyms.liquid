{% comment %}
    Seed Product Search Synonyms (furniture catalogue) on install. Guarded: only runs
    when the table has no records yet, so it never duplicates admin-added synonyms.
    The product_search_synonym table itself is provisioned from
    schema/product_search_synonym.yml on deploy.
{% endcomment %}
{%- graphql existing_synonyms -%}
  query {
    items: records(
      per_page: 1
      filter: {
        table: { value: "modules/ecommerce/product_search_synonym" }
        deleted_at: { exists: false }
      }
    ) {
      total_entries
    }
  }
{%- endgraphql -%}
{%- assign existing_synonyms_count = existing_synonyms.items.total_entries | default: 0 -%}
{%- if existing_synonyms_count == 0 -%}
