{% comment %}
    Seed Product Reviews on install. Guarded: only runs when the reviews table has
    no records yet, so it never duplicates or overwrites real reviews.
    The reviews table itself is provisioned from schema/reviews.yml on deploy.
{% endcomment %}
{%- graphql existing_reviews -%}
  query {
    items: records(
      per_page: 1
      filter: {
        table: { value: "modules/ecommerce/reviews" }
        deleted_at: { exists: false }
      }
    ) {
      total_entries
    }
  }
{%- endgraphql -%}
{%- assign existing_reviews_count = existing_reviews.items.total_entries | default: 0 -%}
{%- if existing_reviews_count == 0 -%}
