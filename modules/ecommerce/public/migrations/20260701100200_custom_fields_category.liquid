{% graphql result, properties: properties %}
mutation save_custom_fields($properties: [NestedPropertyInputType]!) {
  items: admin_table_update(
    physical_file_path: "modules/ins_ecommerce/public/schema/category_custom_field.yml"
    table: { properties: $properties }
  ) {
    id
    name
    parameterized_name
    physical_file_path
    metadata
    properties {
      id
      name
      attribute_type
      belongs_to
      metadata
      options
      default_value
      target_type
      target_id
    }
  }
}

{% endgraphql %}
{% log result, type: "SEED DATA: is_featured" %}


