{% comment %}
    Seed the default Popup Modal record on install. Guarded: only runs when the
    table has no records yet, so it never overwrites a popup an admin has configured.
    The popup_modal table itself is provisioned from schema/popup_modal.yml on deploy.
{% endcomment %}

{%- graphql existing -%}
  query {
    items: records(
      per_page: 1
      filter: {
        table: { value: "modules/ecommerce/popup_modal" }
        deleted_at: { exists: false }
      }
    ) {
      total_entries
    }
  }
{%- endgraphql -%}

{%- assign existing_count = existing.items.total_entries | default: 0 -%}

{%- if existing_count == 0 -%}
    {% parse_json import_popups %}
    [
        {
            "type_name": "modules/ecommerce/popup_modal",
            "properties": {
                "popup_heading": "The living room warehouse reset.",
                "popup_content": "<p>Get premium sofas, cabinets, and lounge sets at up to <strong><span style=\"color:#F24B4B;\">80% OFF</span></strong>.</p>\n",
                "popup_button_label": "Shop living room",
                "popup_button_url": "/products?page=1&per_page=9&categories=living-room,sofas-and-sectionals,storage,side-tables,accent-chairs",
                "is_popup_enabled": true,
                "popup_weight": 100
            }
        }
    ]
    {% endparse_json %}

    {%- graphql results, models: import_popups -%}
        mutation ($models: [CustomizationImport!]!) {
            import_models(models: $models) {
                ids
            }
        }
    {%- endgraphql -%}
    {% log results, type: "SEED DATA: Popup Modal" %}
{%- else -%}
    {% log existing_count, type: "SEED DATA: Popup Modal skipped (records already exist)" %}
{%- endif -%}
